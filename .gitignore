# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files (but keep the documented example).
/.env*
!/.env.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Node modules (Playwright browser driver)
/node_modules

# Test coverage reports
/coverage/

# Ignore key files for decrypting credentials and more.
/config/*.key
/config/credentials/*.key

# SQLite databases belong in /storage (ignored above); never commit one from anywhere else.
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal


/app/assets/builds/*
!/app/assets/builds/.keep

# Gem view symlinks for Tailwind source scanning
/vendor/markdowndocs_views

# macOS metadata
.DS_Store

# Git worktrees
/.worktrees

# Superpowers brainstorm artifacts
/.superpowers

# Local Claude Code settings (per-user, not project config)
/.claude/settings.json

# context-mode hook config (per-user tooling)
/.github/hooks/

# Scratch / reference working files (untracked — e.g. docs-reorg reference copy)
/working_files/
