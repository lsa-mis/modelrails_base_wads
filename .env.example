# Copy this file to .env and fill in the values you need for local development.
# Production secrets live in Rails credentials (bin/rails credentials:edit) or
# in .kamal/secrets — never commit real secrets to .env files.
#
# Every var here has a working default unless marked "required". The full
# reference (with the config that reads each one) lives in app/docs at /docs:
# deployment.md for tuning/hosts, presets.md for tenancy.

# === Rails ===

# Required to run the production-style image locally (e.g. docker compose
# against the prod Dockerfile). Not needed for `bin/dev`.
# RAILS_MASTER_KEY=

# Hostname used to build absolute URLs in mailer links. Defaults to
# example.com — set it on staging/prod or emailed links point nowhere.
# RAILS_HOST=app.example.com

# Log verbosity in production (default: info).
# RAILS_LOG_LEVEL=info

# === Passkeys (WebAuthn) ===

# Passkey relying-party origin override (default: derived from RAILS_HOST).
# Only set if the public origin differs from the app host. See app/docs/developer/passkeys.md.
# WEBAUTHN_ORIGIN=https://app.example.com

# Passkey relying-party ID override (default: hostname from WEBAUTHN_ORIGIN).
# Only set if you need a custom RP ID. See app/docs/developer/passkeys.md.
# WEBAUTHN_RP_ID=app.example.com

# === Kamal deployment ===

# Personal access token or registry password used by `kamal deploy` to push to
# GitHub Container Registry. See config/deploy.yml:registry for the username.
# KAMAL_REGISTRY_PASSWORD=

# === Server tuning (optional — all have working defaults) ===
# See app/docs/developer/deployment.md for the Puma/Solid Queue topology these affect.

# Puma worker processes (default: 1 — correct for a single-box SQLite fork).
# WEB_CONCURRENCY=1

# Puma threads per worker; also the SQLite connection pool size (default: 5 dev / 3 prod).
# RAILS_MAX_THREADS=3

# Solid Queue worker processes (default: 1). Increase only after moving jobs
# out of Puma (SOLID_QUEUE_IN_PUMA, set in config/deploy.yml — not here).
# JOB_CONCURRENCY=1

# Local dev server port (default: 3000).
# PORT=3000

# === Signup gating ===

# Controls public signup behavior (default: invite_only).
# - "invite_only": /registrations/new is closed unless the visitor has a valid
#   invitation token in session
# - "open": anyone can sign up at /registrations/new
# SIGNUP_MODE=invite_only

# Instance ceiling on which workspace join strategies are allowed, comma-
# separated (default: invite). Valid values: invite, open_link. When open_link
# isn't permitted, the workspace setting is shown disabled. See
# app/docs/developer/presets-open-saas.md.
# SIGNUP_PERMITTED_JOIN_STRATEGIES=invite

# === Tenancy preset ===
# Pick a preset at setup time — switching later is a data migration, not a
# config flip. Full matrix in app/docs/developer/presets.md.

# Which workspace (if any) a new user lands in on signup.
# Valid: personal (auto-create their own) · shared (join the one shared workspace) · none (no workspace — identity-only; see app/docs/developer/presets-none.md)
# WORKSPACE_ON_SIGNUP=personal

# Whether the "New workspace" UI + route are available (default: enabled).
# Valid values: enabled, disabled. Set disabled for single-tenant / solo.
# TENANCY_WORKSPACE_CREATION=enabled

# === Shared-preset seeds (only when WORKSPACE_ON_SIGNUP=shared) ===
# Consumed by `bin/rails db:seed` to bootstrap the shared workspace + its
# initial Owner. See app/docs/developer/presets-single-tenant.md.

# Slug for the shared workspace — REQUIRED when WORKSPACE_ON_SIGNUP=shared.
# TENANCY_SHARED_WORKSPACE_SLUG=acme

# Display name for the shared workspace (default: slug titleized).
# TENANCY_SHARED_WORKSPACE_NAME=Acme

# Initial Owner account the seed creates and mails a password-set link to.
# TENANCY_OWNER_EMAIL=owner@example.com
# TENANCY_OWNER_FIRST_NAME=Workspace
# TENANCY_OWNER_LAST_NAME=Owner

# Host used in the seed's logged workspace URL and in the
# `tenancy:owner_setup_link` sign-in link (default: localhost — set on prod).
# APP_HOST=app.example.com
