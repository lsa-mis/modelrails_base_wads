{
  "name": "ModelRails",
  "image": "docker.io/library/ruby:4.0.4-slim",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/git:1": {},
    // moby:false installs Docker CE (Docker's apt repo) instead of Moby, which
    // ships no packages for the base image's Debian 13 "trixie" — with the
    // default (moby:true) the feature fails to install and the build dies.
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": { "moby": false },
    // Node + npm for dev tooling: bin/setup runs `npm ci` (pinned linters —
    // markdownlint, herb-lint) and setup.sh runs `npx playwright`. The ruby:slim
    // base ships no Node and prod doesn't need it (importmap + standalone
    // Tailwind), so Node is dev-container-only. Version tracks .tool-versions.
    "ghcr.io/devcontainers/features/node:1": { "version": "24.4.1" }
  },
  "mounts": [
    "source=modelrails-bundle-cache,target=/usr/local/bundle,type=volume"
  ],
  "remoteEnv": {
    "BINDING": "0.0.0.0"
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Rails",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp",
        "bradlc.vscode-tailwindcss",
        "dbaeumer.vscode-eslint",
        "qwtel.sqlite-viewer"
      ],
      "settings": {
        "editor.tabSize": 2,
        "editor.formatOnSave": true
      }
    }
  }
}
