<% content_for(:title) { t("magic_link_registrations.new.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-text-heading">
    <%= t("magic_link_registrations.new.title") %>
  </h1>

  <p class="mt-2 text-text-muted">
    <%= t("magic_link_registrations.new.subtitle", email: @token_record.email) %>
  </p>

  <%= form_with model: @user, url: magic_link_registration_path(token: @token_record.token), method: :post, class: "mt-8 space-y-6" do |form| %>
    <%= form.error_summary %>

    <%= form.text_field :first_name,
          label: t("magic_link_registrations.new.first_name_label"),
          required: true,
          autofocus: true,
          name: "user[first_name]" %>

    <%= form.text_field :last_name,
          label: t("magic_link_registrations.new.last_name_label"),
          required: true,
          name: "user[last_name]" %>

    <%= form.submit t("magic_link_registrations.new.submit"), class: "w-full" %>
  <% end %>
</div>
