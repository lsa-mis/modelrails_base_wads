<%# locals: (activities:, top_margin: "mt-8") -%>
<%# top_margin defaults to mt-8 for the project-detail page (feed follows other
    content); the Overview passes a tighter value since the feed is its lead
    content and should align with the other shell pages' first heading. -%>
<section aria-label="<%= t('activity.title') %>" class="<%= top_margin %>">
  <h2 class="text-lg font-semibold text-text-heading">
    <%= t("activity.title") %>
  </h2>
  <% if activities.any? %>
    <%# Bordered surface gives the (often sparse) feed a defined edge so it reads
        as an intentional module rather than text floating in whitespace. -%>
    <div class="mt-4 rounded-lg border border-border bg-surface p-4">
      <ol class="space-y-3">
        <%= render partial: "activity_logs/activity_log", collection: activities, as: :activity_log %>
      </ol>
    </div>
  <% else %>
    <div class="mt-4">
      <%= render "shared/empty_state", message: t("activity.empty") %>
    </div>
  <% end %>
</section>
