<header class="sticky top-0 z-40 bg-surface-raised border-b border-border"
        data-controller="mobile-menu"
        data-action="keydown@window->mobile-menu#close click@window->mobile-menu#closeOnOutsideClick">
  <nav aria-label="<%= t("navigation.aria_label") %>"
       class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <%= link_to main_app.root_path,
            class: "flex items-center gap-2 hover:opacity-80 transition-opacity
                    focus-ring rounded" do %>
        <%= render "shared/site_logo", size: :small, show_name: true %>
      <% end %>

      <%# Right cluster. v2 (2026-05-23): the standalone notifications bell
          is removed; the avatar and hamburger button each carry a severity-
          colored indicator dot, and the canonical triage entry point is the
          Notifications row inside the user menu. Theme toggle is desktop-
          only in this row; mobile gets a labeled toggle inside the accordion.
          v3: the hamburger panel holds only global chrome — each layout's
          section sub-nav now renders as an in-page section-nav strip
          instead of hoisting into the panel via content_for. %>
      <div class="flex items-center gap-2">
        <% unless authenticated? %>
          <% if signups_open? %>
            <%= link_to t("navigation.sign_up"), main_app.new_session_path,
                  class: "btn-primary hidden md:inline-flex" %>
          <% end %>
        <% end %>
        <div class="hidden md:block">
          <%= render "shared/theme_toggle", style: :icon %>
        </div>
        <% if authenticated? %>
          <%= render "shared/workspace_switcher" %>
        <% end %>
        <%= render "shared/user_menu", context: :desktop %>

        <%# Mobile menu button. Header-accordion pattern (Path Z) — tapping
            expands the panel downward to reveal the global chrome (workspace
            switcher, user menu, theme toggle) below. The sr-only label
            provides the accessible name; aria-expanded flips between
            true/false on toggle. %>
        <%# The sr-only label flips between "Open menu" and "Close menu"
            based on state — controller toggles textContent in open()/close()
            so AT announces the correct affordance regardless of how
            individual screen readers handle aria-expanded reporting. %>
        <button data-action="click->mobile-menu#toggle"
                data-mobile-menu-target="button"
                data-mobile-menu-open-label-value="<%= t("navigation.mobile_menu.open") %>"
                data-mobile-menu-close-label-value="<%= t("navigation.mobile_menu.close") %>"
                aria-expanded="false"
                aria-controls="mobile-menu-panel"
                class="btn-touch-target relative md:hidden text-text-body
                       focus-ring rounded">
          <span class="sr-only" data-mobile-menu-target="label"><%= t("navigation.mobile_menu.open") %></span>
          <%= icon(:bars_3, size: :lg) %>
          <% if authenticated? %>
            <%# v2: severity-colored indicator dot. Mirrors the avatar's
                indicator (also a positioned sibling, not inside the
                button's accessible-name path) so AT users get notification
                state via the in-menu Notifications row aria-live region,
                not via the hamburger's "Open/Close menu" label. %>
            <turbo-frame id="notifications_indicator_hamburger">
              <%= render "shared/notifications_indicator",
                    summary: unread_notification_summary(Current.user),
                    surface: :hamburger %>
            </turbo-frame>
          <% end %>
        </button>
      </div>
    </div>

    <%# Mobile menu panel. The closeOnLinkClick action delegates via event
        bubbling to any anchor inside, so navigation via the accordion's
        sidebar links auto-dismisses the panel. %>
    <div id="mobile-menu-panel"
         data-mobile-menu-target="menu"
         data-action="click->mobile-menu#closeOnLinkClick"
         aria-label="<%= t("navigation.mobile_menu.aria_label") %>"
         class="hidden md:hidden pb-4 max-h-[calc(100vh-4rem)] overflow-y-auto">
      <%# Mobile accordion — global chrome only. Account menu (identity +
          always-present account actions) leads; the Workspaces group (switcher
          list, capped, + "All workspaces") renders below it so the fixed
          account items keep a predictable position and a growing workspace list
          never pushes them around. Each layout's page-level section sub-nav
          renders as an in-page section-nav strip, not inside this panel. %>
      <div class="flex flex-col gap-2">
        <% if authenticated? %>
          <%= render "shared/user_menu", context: :mobile %>
          <%= render "shared/workspace_switcher", mobile: true %>
        <% else %>
          <%= link_to t("navigation.sign_in"), main_app.new_session_path,
                class: "min-h-[var(--form-input-height)] flex items-center px-2 text-text-body
                        hover:text-interactive-hover rounded
                        focus-ring" %>
          <% if signups_open? %>
            <%= link_to t("navigation.sign_up"), main_app.new_session_path,
                  class: "btn-primary" %>
          <% end %>
        <% end %>
        <%# Display — its own zone (border-t) so the theme toggle reads as a
            third top-level group, not a trailing item under "All workspaces". %>
        <div class="px-1 pt-3 mt-1 border-t border-border">
          <%= render "shared/theme_toggle", style: :labeled %>
        </div>
      </div>
    </div>
  </nav>
</header>
