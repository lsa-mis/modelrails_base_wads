<%# Closing chrome shared by the application and settings layouts: footer,
    biscuit banner, authenticated stream subscriptions, and the SR live region.
    The </body></html> close tags stay in each layout so this partial's own
    tags stay balanced (herb-lint parser-no-errors). -%>
<%= render "shared/footer" %>
<%= biscuit_banner %>

<%= render "shared/authenticated_layout_streams" if authenticated? %>

<%# Screen-reader announcement slot for real-time notification arrivals.
    Empty by default; broadcasts (Task 14 cycle C) update its content,
    and the polite-atomic combo causes assistive tech to re-read the
    full message each time it changes. %>
<div id="notifications-live"
     aria-live="polite"
     aria-atomic="true"
     class="sr-only"></div>
