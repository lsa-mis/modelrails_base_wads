<%# locals: (current_workspace:) -%>
<%# Desktop workspace-sidebar wrapper — provides the <aside> landmark
    and the boxed sidebar visual chrome. Contents (workspace nav items)
    live in _workspace_sidebar_items.html.erb. Below md, the same items
    source instead renders as an in-page section-nav strip (see
    _section_nav_strip) — not this <aside>.

    The workspace switcher now lives exclusively in the header
    (#workspace-switcher-button, Phase 2b). The Settings hub has its
    own sidebar (_settings_sidebar) with destination-specific nav items. -%>
<aside aria-label="<%= t("workspaces.sidebar.aria_label") %>"
       class="w-64 shrink-0 px-4 py-6 border-r border-border bg-surface">
  <%= render "shared/workspace_sidebar_items",
        current_workspace: current_workspace %>
</aside>
