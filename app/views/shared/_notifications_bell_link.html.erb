<%# locals: (user:, summary: nil) -%>
<%# Standalone notifications bell button (D1). Links directly to the
    notifications triage page. The severity indicator overlay is rendered
    inside `notifications_bell_indicator_frame` (broadcast target) so the
    bell link itself stays stable across notification arrivals. The
    aria-labelledby sr-only span lives in `notifications_bell_label_frame`,
    swapped on broadcast so AT announces updated unread counts without
    detaching the focusable link.

    Accepts an optional pre-computed `summary:` local so a parent layout
    can share ONE `unread_notification_breakdown` query across the bell
    + any other notification-aware surface. Falls back to its own query
    when rendered standalone (e.g., via Turbo Stream broadcast). -%>
<% summary ||= unread_notification_summary(user) %>
<%# No turbo_prefetch on the bell — the notifications triage index is a
    paginated query + Pundit + N notification renders, not a free hover. %>
<%= link_to main_app.account_notifications_path,
      id: "notifications-bell-link",
      "aria-labelledby": "notifications_bell_label",
      class: "btn-touch-target relative inline-flex items-center justify-center rounded-full
              text-text-body
              motion-safe:transition-colors motion-safe:duration-150
              hover:bg-surface-sunken hover:text-text-heading
              focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-interactive-focus" do %>
  <turbo-frame id="notifications_bell_label_frame">
    <%= render "shared/notifications_bell_label", user: user, summary: summary %>
  </turbo-frame>
  <%= icon(:bell, size: :md, aria_label: nil) %>
  <%= render "shared/notifications_bell", user: user, summary: summary %>
<% end %>
