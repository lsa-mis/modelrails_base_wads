<%# locals: (title:, message:, confirm_text:, confirm_url:, confirm_method: :delete, variant: :danger, cancel_text: nil, id: nil) -%>
<%
  cancel_label = cancel_text || t("modals.cancel")

  confirm_icon = variant == :danger ? :exclamation_triangle : :information_circle
  icon_color = variant == :danger ? "text-danger-icon" : "text-info-icon"

  confirm_classes = if variant == :danger
    "min-h-[var(--form-input-height)] inline-flex items-center justify-center px-4 rounded-md
     bg-danger hover:bg-danger/90 text-text-on-interactive font-medium
     focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-danger cursor-pointer"
  else
    "min-h-[var(--form-input-height)] inline-flex items-center justify-center px-4 rounded-md
     bg-interactive hover:bg-interactive-hover text-text-on-interactive font-medium
     focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-interactive-focus cursor-pointer"
  end
%>
<%= render "shared/modal", title: title, id: id, size: :sm do %>
  <div class="flex gap-4">
    <div class="shrink-0 mt-0.5 <%= icon_color %>">
      <%= icon(confirm_icon, size: :lg) %>
    </div>
    <p class="text-sm text-text-body leading-relaxed"><%= message %></p>
  </div>

  <div class="flex gap-3 justify-end mt-6 pt-4 border-t border-border">
    <button data-action="click->modal#close"
            class="min-h-[var(--form-input-height)] inline-flex items-center justify-center px-4 rounded-md
                   border border-border text-text-body
                   hover:bg-surface-sunken
                   focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-interactive-focus
                   cursor-pointer">
      <%= cancel_label %>
    </button>
    <%= button_to confirm_text, confirm_url, method: confirm_method,
          class: confirm_classes %>
  </div>
<% end %>
