<%# Dev-only accessibility-simulation drop-up. Renders nothing in production. %>
<% if Rails.env.development? %>
  <%# `blur` stays 2nd and `cataract` last — the keyboard-nav specs pin those positions.
      Color-vision-deficiency variants (deuteranopia..achromatopsia) are grouped together. %>
  <% modes = %w[normal blur grayscale deuteranopia protanopia tritanopia achromatopsia low_contrast cataract] %>
  <% mode_icons = {} %>

  <% mode_icons["normal"] = capture do %>
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4" aria-hidden="true">
      <path d="M1.5 10S5 3 10 3s8.5 7 8.5 7-3.5 7-8.5 7-8.5-7-8.5-7z" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="10" cy="10" r="2.5"/>
    </svg>
  <% end %>

  <% mode_icons["blur"] = capture do %>
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4" aria-hidden="true">
      <circle cx="10" cy="10" r="7" stroke-dasharray="2 2"/>
      <circle cx="10" cy="10" r="3" stroke-dasharray="1.5 2"/>
    </svg>
  <% end %>

  <% mode_icons["grayscale"] = capture do %>
    <svg viewBox="0 0 20 20" class="w-4 h-4" aria-hidden="true">
      <circle cx="10" cy="10" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/>
      <path d="M10 3a7 7 0 010 14z" fill="currentColor"/>
    </svg>
  <% end %>

  <% mode_icons["deuteranopia"] = capture do %>
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4" aria-hidden="true">
      <circle cx="7" cy="10" r="4"/>
      <circle cx="13" cy="10" r="4"/>
    </svg>
  <% end %>

  <%# Dichromacy icons share the two-overlapping-circles motif; the filled cone
      hints at which channel is affected (L/M/S). Decorative (aria-hidden). %>
  <% mode_icons["protanopia"] = capture do %>
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4" aria-hidden="true">
      <circle cx="7" cy="10" r="4" fill="currentColor"/>
      <circle cx="13" cy="10" r="4"/>
    </svg>
  <% end %>

  <% mode_icons["tritanopia"] = capture do %>
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4" aria-hidden="true">
      <circle cx="7" cy="10" r="4"/>
      <circle cx="13" cy="10" r="4" fill="currentColor"/>
    </svg>
  <% end %>

  <% mode_icons["achromatopsia"] = capture do %>
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4" aria-hidden="true">
      <circle cx="10" cy="10" r="7"/>
      <path d="M5.5 14.5 14.5 5.5" stroke-linecap="round"/>
    </svg>
  <% end %>

  <% mode_icons["low_contrast"] = capture do %>
    <svg viewBox="0 0 20 20" class="w-4 h-4" aria-hidden="true">
      <circle cx="10" cy="10" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/>
      <path d="M10 3v14a7 7 0 000-14z" fill="currentColor"/>
    </svg>
  <% end %>

  <% mode_icons["cataract"] = capture do %>
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" class="w-4 h-4" aria-hidden="true">
      <path d="M5 13a3 3 0 010-6 4 4 0 017.9-.5A3 3 0 0115 13H5z" stroke-linejoin="round"/>
    </svg>
  <% end %>

  <%# SVG color-matrix filters for the color-vision-deficiency modes. Each is
      referenced by body.a11y-sim-<mode> via CSS `filter: url(#...)`, so the defs
      must be in-DOM whenever a filter rule can match — hence this dev-only partial.
      Matrices are the standard dichromacy/monochromacy simulation matrices
      (protanopia = L-cone, deuteranopia = M-cone, tritanopia = S-cone,
      achromatopsia = Rec.601 luminance). %>
  <svg class="absolute w-0 h-0 overflow-hidden" aria-hidden="true">
    <defs>
      <filter id="a11y-sim-protanopia" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values="0.567 0.433 0     0 0
                                             0.558 0.442 0     0 0
                                             0     0.242 0.758 0 0
                                             0     0     0     1 0"/>
      </filter>
      <filter id="a11y-sim-deuteranopia" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values="0.625 0.375 0     0 0
                                             0.700 0.300 0     0 0
                                             0     0.300 0.700 0 0
                                             0     0     0     1 0"/>
      </filter>
      <filter id="a11y-sim-tritanopia" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values="0.950 0.050 0     0 0
                                             0     0.433 0.567 0 0
                                             0     0.475 0.525 0 0
                                             0     0     0     1 0"/>
      </filter>
      <filter id="a11y-sim-achromatopsia" color-interpolation-filters="sRGB">
        <feColorMatrix type="matrix" values="0.299 0.587 0.114 0 0
                                             0.299 0.587 0.114 0 0
                                             0.299 0.587 0.114 0 0
                                             0     0     0     1 0"/>
      </filter>
    </defs>
  </svg>

  <div data-controller="a11y-sim"
       data-a11y-sim-announcement-template-value="<%= t("a11y_sim.announcement_template") %>"
       class="relative">
    <button type="button"
            data-a11y-sim-target="trigger"
            data-action="click->a11y-sim#toggle"
            aria-haspopup="true"
            aria-expanded="false"
            aria-label="<%= t("a11y_sim.trigger_aria_label") %>"
            class="inline-flex items-center gap-2 min-h-[var(--form-input-height)] px-3 py-2 text-xs rounded-md
                   bg-warning-surface border border-dashed border-warning
                   text-text-body font-medium
                   hover:brightness-105
                   focus-ring">
      <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-warning-surface text-warning border border-warning tracking-wide"
            aria-hidden="true"><%= t("a11y_sim.dev_badge") %></span>
      <span data-a11y-sim-target="triggerIcon" class="inline-flex"><%= mode_icons["normal"] %></span>
      <span><%= t("a11y_sim.prefix") %></span>
      <span data-a11y-sim-target="triggerLabel" class="font-semibold"><%= t("a11y_sim.modes.normal") %></span>
      <span aria-hidden="true" class="text-[9px]">&#9652;</span>
    </button>

    <div data-a11y-sim-target="menu"
         role="menu"
         aria-label="<%= t("a11y_sim.menu_aria_label") %>"
         class="hidden absolute right-0 bottom-full mb-3 w-64 max-w-[calc(100vw-2rem)]
                rounded-lg bg-surface-overlay border border-border shadow-lg overflow-hidden z-20">
      <div class="flex items-center justify-between px-3 py-2 border-b border-border">
        <span class="text-[10px] font-bold uppercase tracking-wider text-text-muted">
          <%= t("a11y_sim.heading") %>
        </span>
        <span class="text-[10px] font-bold px-1.5 py-0.5 rounded bg-warning-surface text-warning border border-warning tracking-wide"
              aria-hidden="true"><%= t("a11y_sim.dev_badge") %></span>
      </div>

      <% modes.each_with_index do |mode, index| %>
        <button type="button"
                role="menuitemradio"
                aria-checked="<%= mode == "normal" ? "true" : "false" %>"
                data-a11y-sim-target="item"
                data-action="click->a11y-sim#select mouseenter->a11y-sim#showTip mouseleave->a11y-sim#hideTip focus->a11y-sim#showTip blur->a11y-sim#hideTip"
                data-a11y-sim-description="<%= t("a11y_sim.descriptions.#{mode}") %>"
                data-mode="<%= mode %>"
                data-active="<%= mode == "normal" ? "true" : "false" %>"
                class="w-full flex items-center gap-3 min-h-[var(--form-input-height)] px-3 py-2.5 text-sm text-text-body text-left
                       hover:bg-surface-sunken
                       focus:outline-none focus-visible:bg-surface-sunken focus-visible:text-text-heading
                       data-[active=true]:bg-interactive-subtle
                       data-[active=true]:text-interactive
                       data-[active=true]:font-semibold">
          <span data-a11y-sim-icon class="inline-flex shrink-0"><%= mode_icons[mode] %></span>
          <span data-a11y-sim-label class="flex-1"><%= t("a11y_sim.modes.#{mode}") %></span>
          <kbd class="text-[10px] font-mono text-text-muted bg-surface-sunken px-1.5 py-0.5 rounded"><%= index %></kbd>
        </button>
      <% end %>

      <div class="px-3 py-2 border-t border-border text-[10px] text-text-muted font-mono text-right">
        <%= t("a11y_sim.footer_hint") %>
      </div>
    </div>

    <%# Live region for screen-reader announcements when mode changes (WCAG 4.1.3). %>
    <div data-a11y-sim-target="announcer"
         role="status"
         aria-live="polite"
         aria-atomic="true"
         class="sr-only"></div>

    <%# One description tooltip for the whole menu — the controller sets its text +
        fixed position (so it escapes the menu's overflow) on item hover/focus, and
        wires the active item to it via aria-describedby (WCAG 1.4.13). %>
    <div data-a11y-sim-target="tooltip"
         id="a11y-sim-tooltip"
         role="tooltip"
         class="hidden fixed z-30 w-56 max-w-[calc(100vw-2rem)] px-3 py-2 rounded-md
                bg-surface-overlay border border-border shadow-lg
                text-xs leading-snug text-text-body pointer-events-none"></div>
  </div>
<% end %>
