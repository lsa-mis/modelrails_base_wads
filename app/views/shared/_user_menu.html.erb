<%# locals: (context: :desktop) -%>
<%# D1: user menu collapses to two items per context — a clickable
    identity block (avatar + name + email linking to the personal-context
    profile) and a sign-out button. Notifications relocate to the
    standalone header bell; notification preferences remain accessible
    via the Settings hub sidebar. -%>
<% if authenticated? %>
  <% if context == :desktop %>
  <div class="hidden md:flex items-center gap-2">
    <div data-controller="dropdown" class="relative">
      <%= render "shared/user_menu_avatar_button", user: Current.user %>

      <div data-dropdown-target="menu"
           id="user-menu"
           role="menu"
           aria-orientation="vertical"
           aria-labelledby="user-menu-button"
           class="hidden absolute right-0 mt-2 w-64 rounded-lg
                  bg-surface-raised border border-border shadow-lg z-50">
        <%= link_to main_app.edit_account_profile_path,
              role: "menuitem", tabindex: "-1",
              data: { turbo_prefetch: "true" },
              class: "flex items-center gap-3 px-4 py-3 rounded-t-lg
                      hover:bg-surface focus:outline-none focus:bg-surface
                      focus:ring-2 focus:ring-inset focus:ring-interactive-focus" do %>
          <div class="shrink-0 w-10 h-10 rounded-full overflow-hidden">
            <%= avatar_for(Current.user, size: :md) %>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-semibold text-text-heading truncate"><%= Current.user.full_name %></p>
            <p class="text-xs text-text-muted truncate"><%= Current.user.email_address %></p>
          </div>
        <% end %>

        <%# "All workspaces" — the only in-product path to the workspaces
            index on non-workspace-scoped pages (marketing landing, auth
            flows). Path Y Phase C removed the header text-link version of
            this affordance because it sat adjacent to the sidebar switcher
            and got mistaken for it; placing it inside the user menu
            structurally prevents that confusion. Label is deliberately
            "All workspaces" (not "Workspaces") to disambiguate from the
            switcher's "switch workspace" verb. %>
        <div class="border-t border-border">
          <%= link_to t("navigation.all_workspaces"), main_app.workspaces_path,
                role: "menuitem", tabindex: "-1",
                data: { turbo_prefetch: "true" },
                class: "flex items-center min-h-[var(--form-input-height)] px-4 py-2
                        text-sm text-text-body
                        hover:bg-surface hover:text-interactive
                        focus:outline-none focus:ring-2 focus:ring-interactive-focus focus:text-interactive" %>
        </div>

        <div class="border-t border-border">
          <%= button_to t("navigation.sign_out"), main_app.session_path, method: :delete,
                role: "menuitem", tabindex: "-1",
                class: "w-full flex items-center min-h-[var(--form-input-height)] px-4 py-2
                        text-sm text-text-body
                        hover:bg-surface hover:text-interactive
                        focus:outline-none focus:ring-2 focus:ring-interactive-focus focus:text-interactive
                        cursor-pointer" %>
        </div>
      </div>
    </div>
  </div>
  <% end %>

  <% if context == :mobile %>
  <div class="md:hidden">
    <%= link_to main_app.edit_account_profile_path,
          data: { turbo_prefetch: "true" },
          class: "flex items-center gap-3 px-3 py-3 rounded-md
                  hover:bg-surface focus:outline-none focus:bg-surface
                  focus:ring-2 focus:ring-inset focus:ring-interactive-focus" do %>
      <div class="shrink-0 w-10 h-10 rounded-full overflow-hidden">
        <%= avatar_for(Current.user, size: :md) %>
      </div>
      <div class="min-w-0">
        <p class="text-sm font-semibold text-text-heading truncate"><%= Current.user.full_name %></p>
        <p class="text-xs text-text-muted truncate"><%= Current.user.email_address %></p>
      </div>
    <% end %>
    <%# "All workspaces" — see desktop branch above for rationale. %>
    <%= link_to t("navigation.all_workspaces"), main_app.workspaces_path,
          data: { turbo_prefetch: "true" },
          class: "mt-1 w-full min-h-[var(--form-input-height)] flex items-center px-3 py-2
                  text-sm text-text-body
                  hover:bg-surface-sunken hover:text-interactive-hover rounded
                  focus:outline-none focus:ring-2 focus:ring-interactive-focus" %>
    <%= button_to t("navigation.sign_out"), main_app.session_path, method: :delete,
          class: "mt-1 w-full min-h-[var(--form-input-height)] flex items-center px-3 py-2
                  text-sm text-text-body
                  hover:bg-surface-sunken hover:text-interactive-hover rounded
                  focus:outline-none focus:ring-2 focus:ring-interactive-focus cursor-pointer" %>
  </div>
  <% end %>
<% else %>
  <%= link_to t("navigation.sign_in"), main_app.new_session_path,
        class: "min-h-[var(--form-input-height)] flex items-center text-text-body
                hover:text-interactive-hover
                focus:outline-none focus:ring-2 focus:ring-interactive-focus rounded px-2" %>
<% end %>
