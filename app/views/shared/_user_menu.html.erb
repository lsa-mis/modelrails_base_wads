<%# locals: (context: :desktop) -%>
<%# v2 (2026-05-23): the user menu is the canonical triage entry point
    for notifications. The standalone header bell is removed; the avatar
    + hamburger carry severity-colored indicator dots, and tapping into
    the menu surfaces the Notifications row with a live aria-announced
    count. Notification preferences remain inside Settings → Notifications. -%>
<% if authenticated?
     summary = unread_notification_summary(Current.user)
   end %>
<% if authenticated? %>
  <% if context == :desktop %>
  <div class="hidden md:flex items-center gap-2">
    <div data-controller="dropdown" class="relative">
      <%= render "shared/user_menu_avatar_button", user: Current.user %>

      <div data-dropdown-target="menu"
           id="user-menu"
           role="menu"
           aria-orientation="vertical"
           aria-labelledby="user-menu-button"
           class="hidden absolute right-0 mt-2 w-64 rounded-lg
                  bg-surface-raised border border-border shadow-lg z-50">
        <%= link_to main_app.edit_settings_profile_path,
              role: "menuitem", tabindex: "-1",
              data: { turbo_prefetch: "true" },
              class: "flex items-center gap-3 px-4 py-3 rounded-t-lg
                      hover:bg-surface focus:outline-none
                      focus-visible:bg-surface-sunken focus-visible:text-text-heading" do %>
          <div class="shrink-0 w-10 h-10 rounded-full overflow-hidden">
            <%= avatar_for(Current.user, size: :md) %>
          </div>
          <div class="min-w-0">
            <p class="text-sm font-semibold text-text-heading truncate"><%= Current.user.full_name %></p>
            <p class="text-xs text-text-muted truncate"><%= Current.user.email_address %></p>
          </div>
        <% end %>

        <%# v2 Notifications row — the canonical triage entry point.
            Wrapped in notifications_menu_count_frame so the broadcaster
            can swap just the count without re-rendering the whole menu. %>
        <div class="border-t border-border">
          <turbo-frame id="notifications_menu_count_frame">
            <%= render "shared/user_menu_notifications_row", user: Current.user, summary: summary %>
          </turbo-frame>
        </div>

        <%# "Your home" — direct link to /me, the user's personal identity
            and workspace hub. Placed above All workspaces so it is the
            first post-notification action. %>
        <div class="border-t border-border">
          <%= link_to t("navigation.user_menu.home"), main_app.me_path,
                role: "menuitem", tabindex: "-1",
                data: { turbo_prefetch: "true" },
                class: "flex items-center min-h-[var(--form-input-height)] px-4 py-2
                        text-sm text-text-body
                        hover:bg-surface hover:text-interactive
                        focus:outline-none focus-visible:bg-surface-sunken focus-visible:text-text-heading" %>
        </div>

        <%# "All workspaces" — the only in-product path to the workspaces
            index on non-workspace-scoped pages (marketing landing, auth
            flows). Path Y Phase C removed the header text-link version of
            this affordance because it sat adjacent to the sidebar switcher
            and got mistaken for it; placing it inside the user menu
            structurally prevents that confusion. Label is deliberately
            "All workspaces" (not "Workspaces") to disambiguate from the
            switcher's "switch workspace" verb. %>
        <div class="border-t border-border">
          <%= link_to t("navigation.all_workspaces"), main_app.workspaces_path,
                role: "menuitem", tabindex: "-1",
                data: { turbo_prefetch: "true" },
                class: "flex items-center min-h-[var(--form-input-height)] px-4 py-2
                        text-sm text-text-body
                        hover:bg-surface hover:text-interactive
                        focus:outline-none focus-visible:bg-surface-sunken focus-visible:text-text-heading" %>
        </div>

        <div class="border-t border-border">
          <%= button_to t("navigation.sign_out"), main_app.session_path, method: :delete,
                role: "menuitem", tabindex: "-1",
                class: "w-full flex items-center min-h-[var(--form-input-height)] px-4 py-2
                        text-sm text-text-body
                        hover:bg-surface hover:text-interactive
                        focus:outline-none focus-visible:bg-surface-sunken focus-visible:text-text-heading
                        cursor-pointer" %>
        </div>
      </div>
    </div>
  </div>
  <% end %>

  <% if context == :mobile %>
  <div class="md:hidden">
    <%= link_to main_app.edit_settings_profile_path,
          data: { turbo_prefetch: "true" },
          class: "flex items-center gap-3 px-3 py-3 rounded-md
                  hover:bg-surface focus:outline-none
                  focus-visible:bg-surface-sunken focus-visible:text-text-heading" do %>
      <div class="shrink-0 w-10 h-10 rounded-full overflow-hidden">
        <%= avatar_for(Current.user, size: :md) %>
      </div>
      <div class="min-w-0">
        <p class="text-sm font-semibold text-text-heading truncate"><%= Current.user.full_name %></p>
        <p class="text-xs text-text-muted truncate"><%= Current.user.email_address %></p>
      </div>
    <% end %>
    <%# Divider — locks the identity block above as the account-group header
        (the mobile branch drops the desktop per-row hairlines). %>
    <div class="my-2 border-t border-border"></div>
    <%# v2 Notifications row — see desktop branch for context. Mobile version
        styles match the surrounding mobile menuitems. %>
    <%= link_to main_app.settings_notifications_path,
          data: { turbo_prefetch: "true" },
          class: "mt-1 w-full min-h-[var(--form-input-height)] flex items-center justify-between gap-3 px-3 py-2
                  text-sm text-text-body
                  hover:bg-surface-sunken hover:text-interactive-hover rounded
                  focus-ring" do %>
      <%# No icon — the app's icon registry has no home/logout icon, so the
          account rows read as flush text on one column (the count pill on the
          right keeps Notifications scannable). %>
      <span class="flex items-center">
        <%= t("navigation.notifications") %>
      </span>
      <% if summary[:count]&.positive? %>
        <span class="text-xs font-medium text-text-muted"
              aria-live="polite"
              aria-label="<%= t("navigation.notifications_count_aria", count: summary[:count]) %>">
          <%= t("navigation.notifications_count", count: summary[:count]) %>
        </span>
      <% end %>
    <% end %>
    <%# "Your home" — see desktop branch above for rationale. %>
    <%= link_to t("navigation.user_menu.home"), main_app.me_path,
          data: { turbo_prefetch: "true" },
          class: "mt-1 w-full min-h-[var(--form-input-height)] flex items-center px-3 py-2
                  text-sm text-text-body
                  hover:bg-surface-sunken hover:text-interactive-hover rounded
                  focus-ring" %>
    <%# "All workspaces" is rendered in the mobile Workspaces group
        (shared/_workspace_switcher, mobile) below, not here — the account
        group holds only always-present account actions. %>
    <%= button_to t("navigation.sign_out"), main_app.session_path, method: :delete,
          class: "mt-1 w-full min-h-[var(--form-input-height)] flex items-center px-3 py-2
                  text-sm text-text-body
                  hover:bg-surface-sunken hover:text-interactive-hover rounded
                  focus-ring cursor-pointer" %>
  </div>
  <% end %>
<% else %>
  <%= link_to t("navigation.sign_in"), main_app.new_session_path,
        class: "min-h-[var(--form-input-height)] flex items-center text-text-body
                hover:text-interactive-hover
                focus-ring rounded px-2" %>
<% end %>
