<%#
  One-time passkey enrollment interstitial.
  Rendered by the application layout when Current.user.passkey_prompt_eligible?.
  Wraps the webauthn Stimulus controller so the dialog is suppressed on
  unsupported browsers (connect() adds .passkeys-unsupported to this element).
-%>
<div data-controller="webauthn"
     data-webauthn-reg-options-url-value="<%= passkeys_registration_options_path %>"
     data-webauthn-reg-verify-url-value="<%= passkeys_registration_verify_path %>"
     class="[&.passkeys-unsupported]:hidden">
  <%= render UI::DialogComponent.new(
        title: t("passkeys.interstitial.title"),
        description: t("passkeys.interstitial.description"),
        id: "passkey-enrollment-dialog",
        size: :sm,
        open: true,
        wrapper: true) do |d| %>
    <% d.with_trigger do %>
      <%# No visible trigger — dialog opens automatically via open: true %>
      <span class="sr-only"><%= t("passkeys.interstitial.title") %></span>
    <% end %>

    <div class="space-y-4">
      <div>
        <label for="passkey_interstitial_nickname" class="block text-sm font-medium text-text-body mb-1">
          <%= t("passkeys.interstitial.nickname_label") %>
        </label>
        <%= ui :input,
               id: "passkey_interstitial_nickname",
               name: "passkey[nickname]",
               placeholder: t("passkeys.interstitial.nickname_placeholder"),
               autocomplete: "off",
               data: { webauthn_target: "nickname" } %>
      </div>
      <p aria-live="polite" class="text-sm text-text-muted" data-webauthn-target="status"></p>
    </div>

    <% d.with_footer do %>
      <%= button_to t("passkeys.interstitial.skip_button"),
            passkey_prompt_path,
            method: :patch,
            class: "btn-text text-text-body",
            data: { turbo_frame: "_top" } %>
      <button type="button"
              class="btn-secondary"
              data-action="webauthn#register"
              data-webauthn-target="button">
        <%= t("passkeys.interstitial.add_button") %>
      </button>
    <% end %>
  <% end %>
</div>
