<%# locals: (label:, href:, aria_label: nil, active: false, icon: nil) -%>
<%# shrink-0 on the <li> (the flex item) is a no-op in the vertical <aside>
    (flex-col: cross-axis) and stops the horizontal strip's items from squishing
    (flex-row: main-axis), so the row overflows into its scroll instead. -%>
<li class="shrink-0">
  <%= link_to href,
        aria: { label: aria_label, current: ("page" if active) },
        data: { turbo_prefetch: "true" },
        class: [
          "min-h-[44px] flex items-center gap-3 px-3 py-2 rounded-md",
          "text-text-body",
          "motion-safe:transition-colors motion-safe:duration-150",
          "hover:bg-surface-sunken hover:text-text-heading",
          "focus-ring",
          ("bg-surface-sunken font-semibold text-text-heading" if active)
        ].compact do %>
    <% if icon %>
      <span class="shrink-0" aria-hidden="true"><%= icon(icon, size: :sm) %></span>
    <% end %>
    <span><%= label %></span>
  <% end %>
</li>
