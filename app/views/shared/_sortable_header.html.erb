<%# locals: (title:, column:, current_sort:, current_direction:, url:) %>
<%
  active = current_sort == column
  next_direction = active && current_direction == "asc" ? "desc" : "asc"
  arrow = if active
            current_direction == "asc" ? "\u2191" : "\u2193"
          else
            ""
          end
%>
<%= link_to url.call(sort: column, direction: next_direction),
      data: { turbo_frame: "members_results" },
      class: "group inline-flex items-center gap-1 text-sm font-medium text-text-muted
              hover:text-interactive-hover
              focus:outline-none focus:ring-2 focus:ring-interactive-focus rounded" do %>
  <%= title %>
  <% if arrow.present? %>
    <span aria-hidden="true" class="text-interactive"><%= arrow %></span>
  <% end %>
  <% if active %>
    <span class="sr-only"><%= current_direction == "asc" ? "sorted ascending" : "sorted descending" %></span>
  <% end %>
<% end %>
