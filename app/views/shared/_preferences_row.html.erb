<%# locals: (icon_name:, icon_color:, title:, description:, control:) -%>
<%# Reusable row inside a preferences card. Sample-faithful icon-tile-left,
    title+description-middle, control-right layout. `icon_color` accepts one
    of :info / :success / :warning / :danger and maps to the matching
    semantic-tile classes; anything else falls back to a neutral surface. -%>
<%
  icon_classes = case icon_color
                 when :info    then "bg-info-surface text-info-icon"
                 when :success then "bg-success-surface text-success-icon"
                 when :warning then "bg-warning-surface text-warning-icon"
                 when :danger  then "bg-danger-surface text-danger-icon"
                 else               "bg-surface-sunken text-text-heading"
                 end
-%>
<div class="flex items-start gap-4 px-6 py-5">
  <div data-preferences-row-icon
       class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 <%= icon_classes %>">
    <%= icon(icon_name, size: :md) %>
  </div>
  <div class="flex-1 min-w-0">
    <p class="text-sm font-semibold text-text-heading"><%= title %></p>
    <p class="mt-1 text-sm text-text-body"><%= description %></p>
  </div>
  <div class="shrink-0">
    <%= control %>
  </div>
</div>
