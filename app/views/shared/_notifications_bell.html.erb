<%# locals: (user: Current.user, summary: nil) -%>
<%# Slim overlay partial: rendered inside the user-avatar button. Renders
    a solid severity-colored bell at the bottom-right of the avatar when
    there are unread notifications; renders an empty turbo-frame otherwise.
    Solid in both modes — outline rendering loses too much pigment area
    in dark mode and reads as pinkish/coral regardless of the OKLCH point.
    White drop-shadow halo in light mode, black halo in dark mode keeps
    the glyph legible on arbitrary avatar backgrounds.
    Broadcast target is `notifications_bell_indicator_frame`. The
    `summary:` local lets a parent partial (e.g., _user_menu_avatar_button)
    pass a pre-computed summary to avoid a duplicate query. %>
<% bell_user = local_assigns.fetch(:user) { Current.user } %>
<% summary ||= unread_notification_summary(bell_user) %>
<turbo-frame id="notifications_bell_indicator_frame">
  <% if summary[:severity] %>
    <% colors = notification_bell_classes(summary[:severity]) %>
    <%# Windows High Contrast / forced-colors: active overrides author
        colors with system colors, so the bell's severity fill collapses
        to a system color. We force `ButtonText` to keep the glyph
        visible (WCAG 1.4.11 non-text contrast under that accommodation). %>
    <%= icon(:bell, style: :solid,
             class: class_names(
               "absolute -bottom-0.5 right-0.5 w-5 h-5 -rotate-[20deg]",
               "motion-safe:transition-opacity motion-safe:duration-150",
               "[filter:drop-shadow(0_0_2px_white)_drop-shadow(0_0_2px_white)_drop-shadow(0_0_2px_white)]",
               "dark:[filter:drop-shadow(0_0_2px_black)_drop-shadow(0_0_2px_black)_drop-shadow(0_0_2px_black)]",
               "forced-colors:text-[ButtonText]",
               colors[:icon],
               "motion-safe:animate-pulse-danger" => summary[:severity] == :danger
             ),
             data: { bell_severity: canonical_severity(summary[:severity]) },
             aria_label: nil) %>
  <% end %>
</turbo-frame>
