<%# locals: (workspace:) -%>
<%# The identity-bar workspace name — links to the Overview. Rendered from
    both shared/_workspace_identity_bar and workspaces/update.turbo_stream so
    the live bar and the Turbo broadcast target can never drift apart. -%>
<%= link_to workspace_path(workspace),
      id: "workspace-name-heading",
      aria: { label: t("workspaces.identity_bar.overview_link_label", name: workspace.name) },
      class: "min-h-[44px] inline-flex items-center text-lg font-bold text-text-heading truncate rounded focus-ring hover:text-interactive" do %>
  <%= workspace.name %>
<% end %>
