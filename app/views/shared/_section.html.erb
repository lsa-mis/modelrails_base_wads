<%# locals: (title: nil, subtitle: nil, bg: "bg-surface-raised") %>
<section class="<%= bg %> py-16 sm:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <% if title %>
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-text-heading"><%= title %></h2>
        <% if subtitle %>
          <p class="mt-4 text-lg text-text-muted max-w-2xl mx-auto"><%= subtitle %></p>
        <% end %>
      </div>
    <% end %>
    <%= yield %>
  </div>
</section>
