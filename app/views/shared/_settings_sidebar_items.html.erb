<%# locals: (current_workspace:, id_suffix: "") -%>
<%# Chrome-free settings-sidebar contents — nav items only.
    Rendered both inside `_settings_sidebar` (which adds the <aside>
    landmark + sidebar visual chrome for the desktop column) AND directly
    into the mobile-accordion content_for slot (no chrome — contents flow
    inline alongside the rest of the accordion items, matching the
    modelrails_agent_os mobile pattern).

    Workspace switching is handled by the header switcher (#workspace-switcher-button)
    added in Phase 2b — the former in-sidebar switcher has been removed.

    Adding a new sidebar item:
    1. Add i18n keys in config/locales/en/settings.en.yml:
       - settings.sidebar.items.<key>      (visible label)
       - settings.sidebar.aria_labels.<key> (context-disambiguated aria-label, org items only)
    2. If the item should be announced in the aria-live region when the
       workspace context changes, add it to SettingsNavigationHelper#visible_org_sidebar_items
       with the same Pundit policy/action used to gate it here.
    3. Add a render block below in the matching context branch (personal or org).
       Org items wrap in render_nav_item_if_permitted; personal items render unconditionally.
    The sidebar's source of truth for visibility IS the destination controller's Pundit
    policy — never introduce a separate SidebarPolicy. -%>
<% section_label_id = "settings-sidebar-section-label#{id_suffix}" %>

<%# Section label. Personal context covers account-level settings
    (Profile, Notifications, Security, Appearance); org context covers
    workspace-level settings. Rendered as a styled <div> (not a heading)
    so it doesn't conflict with the page's <h1>; programmatically
    associated with the <ul> below via aria-labelledby so screen readers
    announce "Account, list, N items" when entering the navigation. %>
<div id="<%= section_label_id %>"
     class="px-3 mb-2 text-xs font-semibold uppercase tracking-wider text-text-muted">
  <% if settings_context_kind == :personal %>
    <%= t("settings.sidebar.section_label.personal") %>
  <% else %>
    <%= t("settings.sidebar.section_label.org") %>
  <% end %>
</div>

<ul role="list"
    aria-labelledby="<%= section_label_id %>"
    class="flex flex-col gap-1">
  <% if settings_context_kind == :personal %>
    <%= render "shared/settings_sidebar_item",
          label: t("settings.sidebar.items.profile"),
          href: edit_settings_profile_path,
          aria_label: t("settings.sidebar.aria_labels.profile_personal"),
          icon: :user_circle,
          active: current_page?(edit_settings_profile_path) %>

    <%= render "shared/settings_sidebar_item",
          label: t("settings.sidebar.items.notifications"),
          href: edit_settings_notification_preferences_path,
          icon: :bell,
          active: current_page?(edit_settings_notification_preferences_path) %>

    <%= render "shared/settings_sidebar_item",
          label: t("settings.sidebar.items.security"),
          href: settings_connected_accounts_path,
          icon: :shield_check,
          active: current_page?(settings_connected_accounts_path) %>

    <%= render "shared/settings_sidebar_item",
          label: t("settings.sidebar.items.appearance"),
          href: edit_settings_theme_preference_path,
          icon: :color_swatch,
          active: current_page?(edit_settings_theme_preference_path) %>
  <% else %>
    <%# Profile routes to workspaces#edit which authorizes via
        Workspaces::ProfilePolicy (manage_settings permission) — not the
        record's default WorkspacePolicy — so pass policy_class: to keep
        sidebar visibility matched to the destination controller's authorize. %>
    <%= render_nav_item_if_permitted(current_workspace, action: :update?, policy_class: Workspaces::ProfilePolicy) do %>
      <%= render "shared/settings_sidebar_item",
            label: t("settings.sidebar.items.profile"),
            href: edit_workspace_path(current_workspace),
            aria_label: t("settings.sidebar.aria_labels.profile_org",
                          workspace_name: current_workspace.name),
            icon: :user_circle,
            active: current_page?(edit_workspace_path(current_workspace)) %>
    <% end %>

    <%= render_nav_item_if_permitted(Membership.new(workspace: current_workspace), action: :index?) do %>
      <%= render "shared/settings_sidebar_item",
            label: t("settings.sidebar.items.members"),
            href: workspace_members_path(current_workspace),
            aria_label: t("settings.sidebar.aria_labels.members",
                          workspace_name: current_workspace.name),
            icon: :user_group,
            active: current_page?(workspace_members_path(current_workspace)) %>
    <% end %>

    <%= render_nav_item_if_permitted(Invitation.new(invitable: current_workspace), action: :index?) do %>
      <%= render "shared/settings_sidebar_item",
            label: t("settings.sidebar.items.invitations"),
            href: workspace_invitations_path(current_workspace),
            aria_label: t("settings.sidebar.aria_labels.invitations",
                          workspace_name: current_workspace.name),
            icon: :envelope,
            active: current_page?(workspace_invitations_path(current_workspace)) %>
    <% end %>

    <%# Limits & Plan routes to workspaces/settings#edit which authorizes via
        Workspaces::SettingsPolicy (manage_settings permission). The default
        WorkspacePolicy#update? checks manage_workspace — a different permission
        held by Owners but not Admins — so pass policy_class: to keep sidebar
        visibility matched to the destination controller's authorize call. %>
    <%= render_nav_item_if_permitted(current_workspace, action: :update?, policy_class: Workspaces::SettingsPolicy) do %>
      <%= render "shared/settings_sidebar_item",
            label: t("settings.sidebar.items.limits_and_plan"),
            href: edit_workspace_settings_path(current_workspace),
            aria_label: t("settings.sidebar.aria_labels.limits_and_plan",
                          workspace_name: current_workspace.name),
            icon: :chart_bar,
            active: current_page?(edit_workspace_settings_path(current_workspace)) %>
    <% end %>
  <% end %>
</ul>
