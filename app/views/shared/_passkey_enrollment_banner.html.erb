<%#
  Passkey enrollment nudge — a non-blocking, dismissible BANNER (not a modal).
  Shown to eligible users (no kept passkey yet, not previously dismissed). It
  mirrors the email-verification banner: a tinted signal bar with the text in
  the signal colour (AAA-proven), inline actions as underlined links.

  "Add a passkey" links to Settings → Passkeys (the named add flow lives there);
  the dismiss button PATCHes passkey_prompt_path, which stamps
  passkey_prompt_seen_at so the banner never re-appears (no re-nag). The whole
  banner hides on browsers without WebAuthn support — the webauthn Stimulus
  controller adds .passkeys-unsupported in connect().
-%>
<% if authenticated? && Current.user.passkey_prompt_eligible? %>
  <div id="passkey-banner"
       role="region"
       aria-label="<%= t("passkeys.banner.heading") %>"
       data-controller="webauthn"
       class="bg-info-surface text-info info-border border-b [&.passkeys-unsupported]:hidden">
    <div class="max-w-5xl mx-auto px-4 py-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm">
      <%= icon(:finger_print, class: "w-4 h-4 shrink-0") %>
      <span><%= t("passkeys.banner.message") %></span>
      <%= link_to t("passkeys.banner.add"), settings_passkeys_path,
            class: "font-semibold underline hover:no-underline focus-ring rounded" %>
      <%= button_to passkey_prompt_path,
            method: :patch,
            form: { class: "ml-auto inline" },
            class: "inline-flex items-center font-semibold underline hover:no-underline focus-ring rounded",
            aria: { label: t("passkeys.banner.dismiss") } do %>
        <%= icon(:x_mark, class: "w-4 h-4") %>
      <% end %>
    </div>
  </div>
<% end %>
