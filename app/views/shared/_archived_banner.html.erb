<%# locals: (message:, restore_path:) %>
<div class="mb-6 rounded-lg border border-info-border bg-info-surface p-4 flex items-center justify-between gap-4"
     role="status" data-test="archived-banner">
  <p class="text-sm text-info"><%= message %></p>
  <%= button_to t("lifecycle.restore"), restore_path, method: :patch,
        class: "btn-touch-target btn-text btn-text-interactive text-sm shrink-0" %>
</div>
