<%# Desktop account-settings sidebar — the <aside> landmark and boxed chrome
    (256px, surface bg, right border). Contents are the account (identity)
    settings items; below md the same source renders as an in-page section-nav
    strip (see _section_nav_strip) — not this <aside>. -%>
<aside aria-label="<%= t("settings.sidebar.aria_label") %>"
       class="w-64 shrink-0 px-4 py-6 border-r border-border bg-surface">
  <%= render "shared/identity_settings_sidebar_items" %>
</aside>
