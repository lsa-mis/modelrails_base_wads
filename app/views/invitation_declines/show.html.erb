<% content_for(:title) { t("invitation_declines.show.title") } %>
<div class="max-w-md mx-auto px-4 py-16 text-center">
  <h1 class="text-2xl font-bold text-text-heading">
    <%= t("invitation_declines.show.title") %>
  </h1>

  <p class="mt-4 text-text-muted">
    <%= t("invitation_declines.show.body", workspace: @invitation.invitable.name) %>
  </p>

  <%= button_to t("invitation_declines.show.confirm"),
        decline_invitation_path(token: @invitation.token),
        method: :post,
        class: "mt-8 w-full min-h-[var(--form-input-height)] rounded-md px-4 py-2
                border border-danger text-danger font-medium
                hover:bg-danger-hover
                focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-danger
                cursor-pointer" %>
</div>
