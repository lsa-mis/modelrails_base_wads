<% content_for(:title) { t("invitation_accepts.show.title") } %>
<div class="max-w-md mx-auto px-4 py-16 text-center">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-gray-100">
    <%= t("invitation_accepts.show.title") %>
  </h1>

  <p class="mt-4 text-slate-600 dark:text-gray-400">
    <%= t("invitation_accepts.show.body",
          inviter: @invitation.invited_by.full_name,
          workspace: @invitation.invitable.name,
          role: @invitation.role.name) %>
  </p>

  <% if authenticated? %>
    <%= button_to t("invitation_accepts.show.accept"),
          accept_invitation_path(token: @invitation.token),
          method: :post,
          class: "mt-8 w-full min-h-[44px] rounded-md px-4 py-2
                  bg-sky-700 hover:bg-sky-800 text-white font-medium
                  focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-sky-700
                  cursor-pointer" %>
  <% else %>
    <div class="mt-8 space-y-4">
      <%= link_to t("invitation_accepts.show.sign_in"), new_session_path,
            class: "block w-full min-h-[44px] flex items-center justify-center rounded-md px-4 py-2
                    bg-sky-700 hover:bg-sky-800 text-white font-medium
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-sky-700" %>
      <%= link_to t("invitation_accepts.show.register"), new_registration_path,
            class: "block w-full min-h-[44px] flex items-center justify-center rounded-md px-4 py-2
                    border border-sky-700 text-sky-700 dark:text-sky-400 font-medium
                    hover:bg-sky-50 dark:hover:bg-sky-900
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-sky-700" %>
    </div>
  <% end %>
</div>
