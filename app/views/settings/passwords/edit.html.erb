<% content_for(:title) { t("settings.passwords.edit.title") } %>

<div class="max-w-md mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold text-text-heading">
    <%= t("settings.passwords.edit.title") %>
  </h1>

  <%= form_with model: Current.user, url: settings_password_path, method: :patch, class: "mt-8 space-y-6" do |form| %>
    <%= form.error_summary %>

    <%= form.password_field :password,
          label: t("settings.passwords.edit.password_label"),
          required: true,
          autocomplete: "new-password",
          help: t("settings.passwords.edit.password_hint") %>

    <%= form.password_field :password_confirmation,
          label: t("settings.passwords.edit.password_confirmation_label"),
          required: true,
          autocomplete: "new-password" %>

    <%= form.submit t("settings.passwords.edit.submit"), class: "w-full" %>
  <% end %>

  <%= button_to t("settings.passwords.edit.remove"), settings_password_path,
        method: :delete, class: "btn-text-danger w-full mt-4" %>
</div>
