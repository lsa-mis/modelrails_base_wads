<% content_for(:title) { t("settings.connected_accounts.index.title") } %>
<div class="page-container py-16">
  <%= render "shared/settings_page_header",
        title: t("settings.pages.security.h1"),
        description: t("settings.pages.security.description") %>

  <%= turbo_stream_from Current.user, :authentications %>

  <% if (auth_id = flash[:confirming_email_for]) && (pending = @authentications.find { |a| a.id == auth_id }) %>
    <div class="mt-6 rounded-lg border border-info-border bg-info-surface p-4 text-sm text-info" role="status" aria-live="polite" aria-atomic="true">
      <%= t("settings.connected_accounts.index.confirming_banner_html", email: pending.email, provider: pending.display_provider) %>
    </div>
  <% end %>

  <% verified_count = @authentications.count(&:verified?) %>
  <ul role="list" class="mt-8 space-y-4">
    <% @authentications.each do |authentication| %>
      <li class="flex items-center justify-between p-4 border rounded-lg <%= authentication.pending? ? "bg-info-surface border-info-border" : "border-border" %>">
        <div>
          <%# When this is the sole verified method, associate the heading with
              the "only sign-in method" note so a screen reader reads the reason
              the row has no Unlink action. %>
          <%= tag.p class: "font-medium text-text-heading",
                    aria: { describedby: (("auth-#{authentication.id}-sole") unless authentication.pending? || verified_count > 1) } do %>
            <%= authentication.display_provider %>
            <span class="sr-only">
              <%= authentication.pending? ? t("settings.connected_accounts.index.pending_state_sr") : t("settings.connected_accounts.index.verified_state_sr") %>
            </span>
          <% end %>
          <% if authentication.pending? %>
            <p class="text-xs text-info">
              <%= t("settings.connected_accounts.index.pending_label", email: authentication.email) %>
            </p>
            <p class="text-xs text-text-muted mt-1">
              <%= t("settings.connected_accounts.index.pending_help") %>
            </p>
          <% else %>
            <p class="text-sm text-text-muted">
              <% if authentication.email? %>
                <%= Current.user.has_password? ? t("settings.connected_accounts.index.email_provider") : t("settings.connected_accounts.index.email_provider_passwordless") %>
              <% else %>
                <%= authentication.email.presence || authentication.uid %>
              <% end %>
            </p>
            <% if authentication.verified? %>
              <span class="inline-flex items-center px-2.5 py-1 rounded bg-success-surface text-xs font-medium text-success">
                <%= t("settings.connected_accounts.index.verified") %>
              </span>
            <% end %>
          <% end %>
        </div>

        <div class="action-group">
          <% if authentication.pending? %>
            <%= button_to t("settings.connected_accounts.index.resend_action"),
                  resend_verification_settings_connected_account_path(authentication),
                  method: :post,
                  aria: { label: t("settings.connected_accounts.index.resend_action_aria_label", provider: authentication.display_provider) },
                  class: "btn-touch-target btn-text btn-text-interactive text-sm",
                  form: { class: "inline" } %>
            <%= button_to t("settings.connected_accounts.index.cancel_action"),
                  settings_connected_account_path(authentication),
                  method: :delete,
                  aria: { label: t("settings.connected_accounts.index.cancel_action_aria_label", provider: authentication.display_provider) },
                  class: "btn-touch-target btn-text btn-text-danger text-sm",
                  form: { class: "inline" } %>
          <% elsif verified_count <= 1 %>
            <p id="auth-<%= authentication.id %>-sole" class="text-sm text-text-muted"><%= t("settings.connected_accounts.index.only_method_note") %></p>
          <% else %>
            <div data-controller="modal" class="inline">
              <button type="button"
                      data-action="click->modal#open"
                      aria-label="<%= t("settings.connected_accounts.index.disconnect_action_aria_label", provider: authentication.display_provider) %>"
                      class="btn-touch-target btn-text btn-text-danger text-sm">
                <%= t("settings.connected_accounts.index.disconnect") %>
              </button>

              <%= render "shared/confirm_dialog",
                    title: t("settings.connected_accounts.index.disconnect_title", provider: authentication.display_provider),
                    message: t("settings.connected_accounts.index.disconnect_message", provider: authentication.display_provider, email: authentication.email),
                    confirm_text: t("settings.connected_accounts.index.disconnect"),
                    confirm_url: settings_connected_account_path(authentication),
                    confirm_method: :delete,
                    variant: :danger %>
            </div>
          <% end %>
        </div>
      </li>
    <% end %>
  </ul>
</div>
