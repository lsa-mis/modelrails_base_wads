<!DOCTYPE html>
<html lang="<%= I18n.locale %>"
      data-controller="theme"
      data-theme-theme-value="<%= current_user_theme %>">
<%= render "shared/layout_head" %>

  <body class="min-h-screen flex flex-col bg-surface-raised text-text-heading">
    <%= render "shared/skip_link" %>

    <%# Path Z header-accordion pattern: when there's a workspace context,
        the workspace sidebar renders inline on desktop (md+) and is
        surfaced inside the shared header's expanded mobile panel via
        content_for(:mobile_menu_sidebar). One eager-loaded workspaces
        relation feeds both renders. content_for MUST be declared before
        render "shared/header" so the slot is populated when the header
        reads it. %>
    <% if Current.workspace %>
      <%# Mobile accordion: chrome-free contents partial so the workspace
          nav items flow inline rather than appearing as a nested sidebar.
          Desktop column below still renders the full _workspace_sidebar
          wrapper with the <aside> chrome.
          id_suffix: "-mobile" so the section-label ID doesn't collide
          with the desktop render below. %>
      <% content_for :mobile_menu_sidebar do %>
        <%= render "shared/workspace_sidebar_items",
              current_workspace: Current.workspace,
              id_suffix: "-mobile" %>
      <% end %>
      <% content_for :mobile_menu_sidebar_aria_label, t("workspaces.sidebar.aria_label") %>
    <% end %>

    <%= render "shared/header" %>
    <%= render "shared/toasts" %>

    <% if Current.workspace %>
      <div class="flex-1 flex flex-col md:flex-row min-h-[calc(100vh-4rem)]">
        <%# Desktop sidebar — hidden below md where the header accordion
            surfaces the same _workspace_sidebar partial. %>
        <div class="hidden md:flex shrink-0">
          <%= render "shared/workspace_sidebar",
                current_workspace: Current.workspace %>
        </div>

        <main id="main-content"
              tabindex="-1"
              class="flex-1 min-w-0"
              <% ws_hue = Current.workspace.primary_color || 210 %>
              data-workspace-branded
              style="--ws-primary-light: oklch(0.40 0.15 <%= ws_hue %>); --ws-primary-dark: oklch(0.78 0.10 <%= ws_hue %>);">
          <%= render "shared/workspace_back_link" %>
          <%= yield %>
        </main>
      </div>
    <% else %>
      <main id="main-content"
            tabindex="-1"
            class="flex-1">
        <%= render "shared/workspace_back_link" %>
        <%= yield %>
      </main>
    <% end %>

    <%= render "shared/layout_tail" %>
  </body>
</html>
