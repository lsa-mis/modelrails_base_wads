<!DOCTYPE html>
<html lang="<%= I18n.locale %>"
      data-controller="theme"
      data-theme-theme-value="<%= current_user_theme %>">
  <head>
    <title><%= content_for(:title) || t("application.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || t("application.description") %>">
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/manifest.webmanifest">
    <%= render "shared/theme_script" %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "biscuit/biscuit", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen flex flex-col bg-surface-raised text-text-heading">
    <a href="#main-content"
       class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:p-4 focus:bg-surface-raised focus:text-interactive focus:underline">
      <%= t("application.skip_to_content") %>
    </a>

    <%# Path Z header-accordion pattern: when there's a workspace context,
        the workspace sidebar renders inline on desktop (md+) and is
        surfaced inside the shared header's expanded mobile panel via
        content_for(:mobile_menu_sidebar). One eager-loaded workspaces
        relation feeds both renders. content_for MUST be declared before
        render "shared/header" so the slot is populated when the header
        reads it. %>
    <% workspaces_scope = Current.workspace ? Current.user.workspaces.kept.includes(:logo_attachment, memberships: [ :role, { user: :avatar_attachment } ]) : nil %>
    <% if Current.workspace %>
      <%# Mobile accordion: chrome-free contents partial so the workspace
          switcher + nav items flow inline rather than appearing as a
          nested sidebar. Desktop column below still renders the full
          _workspace_sidebar wrapper with the <aside> chrome.
          id_suffix: "-mobile" so IDs (switcher button/menu, section
          label) don't collide with the desktop render below. %>
      <% content_for :mobile_menu_sidebar do %>
        <%= render "shared/workspace_sidebar_items",
              workspaces: workspaces_scope,
              current_workspace: Current.workspace,
              id_suffix: "-mobile" %>
      <% end %>
      <% content_for :mobile_menu_sidebar_aria_label, t("workspaces.sidebar.aria_label") %>
    <% end %>

    <%= render "shared/header" %>
    <%= render "shared/toasts" %>

    <% if Current.workspace %>
      <div class="flex-1 flex flex-col md:flex-row min-h-[calc(100vh-4rem)]">
        <%# Desktop sidebar — hidden below md where the header accordion
            surfaces the same _workspace_sidebar partial. %>
        <div class="hidden md:flex shrink-0">
          <%= render "shared/workspace_sidebar",
                workspaces: workspaces_scope,
                current_workspace: Current.workspace %>
        </div>

        <main id="main-content"
              tabindex="-1"
              class="flex-1 min-w-0"
              <% ws_hue = Current.workspace.primary_color || 210 %>
              data-workspace-branded
              style="--ws-primary-light: oklch(0.40 0.15 <%= ws_hue %>); --ws-primary-dark: oklch(0.78 0.10 <%= ws_hue %>);">
          <%= render "shared/workspace_back_link" %>
          <%= yield %>
        </main>
      </div>
    <% else %>
      <main id="main-content"
            tabindex="-1"
            class="flex-1">
        <%= render "shared/workspace_back_link" %>
        <%= yield %>
      </main>
    <% end %>

    <%= render "shared/footer" %>
    <%= biscuit_banner %>

    <%= render "shared/authenticated_layout_streams" if authenticated? %>

    <%# Screen-reader announcement slot for real-time notification arrivals.
        Empty by default; broadcasts (Task 14 cycle C) update its content,
        and the polite-atomic combo causes assistive tech to re-read the
        full message each time it changes. %>
    <div id="notifications-live"
         aria-live="polite"
         aria-atomic="true"
         class="sr-only"></div>
  </body>
</html>
