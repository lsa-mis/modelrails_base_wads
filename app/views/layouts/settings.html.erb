<!DOCTYPE html>
<html lang="<%= I18n.locale %>"
      data-controller="theme"
      data-theme-theme-value="<%= current_user_theme %>">
<%# Turbo morph for the account settings hub (#327). Must run before the head
    partial so its provide(:head) is buffered when _layout_head yields :head. %>
<% turbo_refreshes_with method: :morph %>
<%= render "shared/layout_head" %>

  <body class="min-h-screen flex flex-col bg-surface-raised text-text-heading">
    <%= render "shared/skip_link" %>

    <%# Account-only settings hub. At md+ the identity sidebar renders inline
        to the left of <main>; below md, a section_nav_strip renders as the
        first child of <main> instead. No workspace context here — account
        settings are the signed-in user's own, unrelated to any workspace. %>
    <%= render "shared/header" %>
    <%= render "shared/toasts" %>

    <div class="flex-1 flex flex-col md:flex-row">
      <%# Desktop sidebar — hidden below md where the section_nav_strip
          inside <main> surfaces the same items instead. %>
      <div class="hidden md:flex shrink-0">
        <%= render "shared/settings_sidebar" %>
      </div>

      <main id="main-content" tabindex="-1" class="flex-1 min-w-0 px-6">
        <%= render "shared/section_nav_strip",
              items: identity_settings_nav_items,
              heading: t("settings.sidebar.strip_heading.identity") %>
        <%= yield %>
      </main>
    </div>

    <%= render "shared/layout_tail" %>
  </body>
</html>
