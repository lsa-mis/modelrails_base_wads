<!DOCTYPE html>
<html lang="<%= I18n.locale %>"
      data-controller="theme"
      data-theme-theme-value="<%= current_user_theme %>">
<%# Turbo morph for the settings hub (#327). Must run before the head partial
    so its provide(:head) is buffered when _layout_head yields :head. The
    settings-announcer controller and the switcher's idiomorph-safe IDs are
    built for this. %>
<% turbo_refreshes_with method: :morph %>
<%= render "shared/layout_head" %>

  <body class="min-h-screen flex flex-col bg-surface-raised text-text-heading">
    <%= render "shared/skip_link" %>

    <%# Polite aria-live region for settings context-change announcements
        (WCAG 4.1.3). Visually hidden via sr-only — do NOT use hidden,
        which removes the node from the accessibility tree. The Stimulus
        controller listens for turbo:render and writes the appropriate
        template (personal or org) on each settings-hub navigation. %>
    <div id="settings-aria-live"
         role="status"
         aria-live="polite"
         aria-atomic="true"
         class="sr-only"
         data-controller="settings-announcer"
         data-settings-announcer-personal-value="<%= t("settings.sidebar.aria_live_template.personal") %>"
         data-settings-announcer-org-value="<%= current_workspace_announcement_for_aria_live %>">
    </div>

    <%# Settings hub layout. Path Z header-accordion pattern: at md+ the
        sidebar renders inline to the left of <main> with the <aside>
        chrome (_settings_sidebar wrapper); below md, the *chrome-free*
        contents partial (_settings_sidebar_items) is surfaced via
        content_for(:mobile_menu_sidebar) so the switcher + nav items
        flow inline inside the header accordion instead of appearing as
        a nested sidebar-within-a-menu. One eager-loaded workspaces
        relation feeds both renders to avoid an N+1 on the doubly-rendered
        contents. content_for MUST be declared before render
        "shared/header" so the slot is populated when the header reads it. %>
    <% workspaces_scope = Current.user.workspaces.kept.includes(:logo_attachment, memberships: [ :role, { user: :avatar_attachment } ]) %>
    <% content_for :mobile_menu_sidebar do %>
      <%= render "shared/settings_sidebar_items",
            workspaces: workspaces_scope,
            current_workspace: Current.workspace,
            id_suffix: "-mobile" %>
    <% end %>
    <% content_for :mobile_menu_sidebar_aria_label, t("settings.sidebar.aria_label") %>

    <%= render "shared/header" %>
    <%= render "shared/toasts" %>

    <div class="flex-1 flex flex-col md:flex-row min-h-[calc(100vh-4rem)]"
         data-workspace-kind="<%= settings_context_kind %>">
      <%# Desktop sidebar — hidden below md where the header accordion
          surfaces the same _settings_sidebar partial. %>
      <div class="hidden md:flex shrink-0">
        <%= render "shared/settings_sidebar",
              workspaces: workspaces_scope,
              current_workspace: Current.workspace %>
      </div>

      <main id="main-content"
            tabindex="-1"
            class="flex-1 min-w-0 px-6 py-8"
            <% if Current.workspace %>
              <% ws_hue = Current.workspace.primary_color || 210 %>
              data-workspace-branded
              style="--ws-primary-light: oklch(0.40 0.15 <%= ws_hue %>); --ws-primary-dark: oklch(0.78 0.10 <%= ws_hue %>);"
            <% end %>>
        <%= yield %>
      </main>
    </div>

    <%= render "shared/layout_tail" %>
  </body>
</html>
