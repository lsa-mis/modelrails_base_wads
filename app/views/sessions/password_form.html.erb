<% content_for(:title) { t("sessions.password_form.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-gray-100">
    <%= t("sessions.password_form.title") %>
  </h1>

  <p class="mt-2 text-slate-600 dark:text-gray-400"><%= @email_address %></p>

  <%= form_with url: main_app.session_path, class: "mt-8 space-y-6" do |form| %>
    <%= form.hidden_field :email_address, value: @email_address %>

    <div>
      <%= form.label :password, t("sessions.password_form.password_label"),
            class: "block text-sm font-medium text-slate-700 dark:text-gray-300" %>
      <%= form.password_field :password,
            required: true,
            autofocus: true,
            autocomplete: "current-password",
            class: "mt-1 block w-full rounded-md border border-gray-300 dark:border-gray-600
                    bg-white dark:bg-gray-800 px-3 py-2
                    text-slate-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-sky-700 focus:border-sky-700" %>
    </div>

    <%= form.submit t("sessions.password_form.submit"),
          class: "w-full min-h-[44px] rounded-md px-4 py-2
                  bg-sky-700 hover:bg-sky-800 text-white font-medium
                  focus:outline-none focus:ring-2 focus:ring-sky-700 focus:ring-offset-2
                  cursor-pointer" %>
  <% end %>

  <p class="mt-4 text-sm text-slate-600 dark:text-gray-400">
    <%= t("sessions.lookup.password_prompt") %>
  </p>
</div>
