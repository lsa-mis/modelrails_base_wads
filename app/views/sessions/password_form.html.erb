<%= turbo_frame_tag "sign_in_form" do %>
  <p class="mt-4 text-sm text-slate-600 dark:text-gray-400"><%= @email_address %></p>

  <p class="mt-1 text-sm text-slate-600 dark:text-gray-400"><%= t("sessions.lookup.password_prompt") %></p>

  <%= form_with url: main_app.session_path, class: "mt-6 space-y-6" do |form| %>
    <%= form.hidden_field :email_address, value: @email_address %>

    <div>
      <%= form.label :password, t("sessions.password_form.password_label"),
            class: "block text-sm font-medium text-slate-700 dark:text-gray-300" %>
      <%= form.password_field :password,
            required: true,
            autofocus: true,
            autocomplete: "current-password",
            maxlength: 72,
            class: "mt-1 block w-full rounded-md border border-gray-300 dark:border-gray-600
                    bg-white dark:bg-gray-800 px-3 py-2
                    text-slate-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-sky-700 focus:border-sky-700" %>
    </div>

    <%= form.submit t("sessions.password_form.submit"),
          class: "w-full min-h-[44px] rounded-md px-4 py-2
                  bg-sky-700 hover:bg-sky-800 text-white font-medium
                  focus:outline-none focus:ring-2 focus:ring-sky-700 focus:ring-offset-2
                  cursor-pointer" %>
  <% end %>

  <div class="mt-4 flex flex-col gap-2 text-sm text-center">
    <%= button_to t("sessions.password_form.use_magic_link"),
          main_app.magic_link_path,
          params: { email_address: @email_address },
          method: :post,
          class: "text-sky-700 dark:text-sky-400 underline hover:no-underline
                  focus:outline-none focus:ring-2 focus:ring-sky-700 rounded cursor-pointer" %>
    <%= link_to t("sessions.new.forgot_password"), main_app.new_password_path,
          class: "text-sky-700 dark:text-sky-400 underline hover:no-underline
                  focus:outline-none focus:ring-2 focus:ring-sky-700 rounded",
          data: { turbo_frame: "_top" } %>
  </div>
<% end %>
