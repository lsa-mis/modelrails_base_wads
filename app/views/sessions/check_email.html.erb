<%= turbo_frame_tag "sign_in_form" do %>
  <div class="mt-8 text-center">
    <div class="mx-auto w-16 h-16 rounded-full bg-sky-100 dark:bg-sky-900 flex items-center justify-center mb-6">
      <svg class="w-8 h-8 text-sky-700 dark:text-sky-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
    </div>

    <h2 class="text-xl font-semibold text-slate-900 dark:text-gray-100">
      <%= t("sessions.check_email.title") %>
    </h2>

    <p class="mt-3 text-slate-600 dark:text-gray-400">
      <%= t("sessions.check_email.description", email: @email_address) %>
    </p>

    <p class="mt-6 text-sm text-slate-500 dark:text-gray-500">
      <%= t("sessions.check_email.expiry") %>
    </p>

    <div class="mt-6">
      <%= link_to t("sessions.check_email.try_again"), main_app.new_session_path,
            class: "text-sm text-sky-700 dark:text-sky-400 underline hover:no-underline
                    focus:outline-none focus:ring-2 focus:ring-sky-700 rounded",
            data: { turbo_frame: "_top" } %>
    </div>
  </div>
<% end %>
