<%
  prefs_object = @preferences.notification_preferences_object
  prefs = @preferences.notification_preferences

  # Icon mapping for the Notification Types card. The icon set in
  # app/assets/icons/outline is sparse; pick the closest semantic match
  # for each category. Security uses :warning to signal "this row is
  # structurally different" (always-on, non-suppressible).
  type_icons = {
    "security"           => { name: "exclamation_triangle", color: :warning },
    "account_access"     => { name: "bell",                 color: :info },
    "workspace_activity" => { name: "globe_alt",            color: :info },
    "project_activity"   => { name: "pencil",               color: :info },
    "billing"            => { name: "information_circle",   color: :info }
  }
%>
<section aria-labelledby="notification-preferences-heading"
         class="max-w-3xl mx-auto px-4 py-8 space-y-6
                sm:px-6
                lg:px-8">
  <header>
    <h1 id="notification-preferences-heading"
        class="text-2xl font-semibold text-text-heading">
      <%= t("notifications.preferences.heading") %>
    </h1>
  </header>

  <%# Migration banner — renders only until the user dismisses it once.
      Turbo replaces this frame with an empty body on dismiss, so the
      banner vanishes without a full page reload. -%>
  <% if @preferences.dismissed_notifications_redesign_banner_at.nil? %>
    <%= render "migration_banner" %>
  <% else %>
    <%= turbo_frame_tag "notifications_redesign_banner" %>
  <% end %>

  <%# === Timezone surface (Phase 0.5 — unchanged) ===================
      Surfaces the currently-stored timezone (set by the layout-level
      beacon on layout connect for users without an explicit value).
      The Change action posts to the same endpoint with override=true
      so the no-overwrite guard is bypassed for explicit user intent. -%>
  <details class="bg-surface-raised border border-border rounded-lg p-6 group">
    <summary class="cursor-pointer list-none flex items-baseline gap-2
                    focus:outline-none focus:ring-2 focus:ring-interactive-focus rounded">
      <span class="text-sm font-semibold text-text-heading">
        <%= t("notifications.preferences.timezone.heading") %>:
      </span>
      <span class="text-sm text-text-body">
        <strong class="text-text-heading"><%= @preferences.timezone.presence || "UTC" %></strong>
      </span>
      <span class="ml-2 text-sm text-interactive font-medium underline
                   group-open:hidden">
        <%= t("notifications.preferences.timezone.change") %>
      </span>
      <span class="ml-2 text-sm text-interactive font-medium underline
                   hidden group-open:inline">
        <%= t("notifications.preferences.timezone.cancel") %>
      </span>
    </summary>
    <%= form_with url: account_preferences_timezone_path,
          method: :patch,
          class: "mt-4 flex flex-wrap items-end gap-3" do |f| %>
      <input type="hidden" name="override" value="true">
      <%= f.label :timezone,
            t("notifications.preferences.timezone.picker_label"),
            class: "block text-sm font-medium text-text-heading mb-1" %>
      <%= f.select :timezone,
            grouped_options_for_select(
              timezone_options_for_select,
              @preferences.timezone
            ),
            {},
            class: "min-h-[44px] px-3 rounded-md bg-surface text-text-body border border-border-strong focus:outline-none focus:ring-2 focus:ring-interactive-focus" %>
      <%= f.submit t("notifications.preferences.timezone.save"),
            class: "min-h-[44px] px-4 rounded-md bg-interactive text-text-on-interactive font-medium hover:bg-interactive-hover focus:outline-none focus:ring-2 focus:ring-interactive-focus" %>
    <% end %>
  </details>

  <%# === Card 1: Notification Types ================================
      5 rows, one per category. Security row is disabled+always-on
      (the value object forces it true regardless; the disabled
      checkbox + hidden field "true" round-trip preserves the
      always-on guarantee even if the form is tampered with). -%>
  <%= render layout: "shared/preferences_card",
        locals: {
          title: t("notifications.preferences.notification_types.heading"),
          description: t("notifications.preferences.notification_types.description")
        } do %>
    <% NotificationPreferences::CATEGORIES.each do |category| %>
      <% security = (category == "security") %>
      <% type_control = capture do %>
        <%= form_with url: account_notification_preferences_path,
              method: :patch,
              data: { controller: "auto-submit" },
              class: "inline-block" do |f| %>
          <%= render "shared/toggle",
                name: "notification_preferences[notification_types][#{category}]",
                label: t("notifications.preferences.notification_types.items.#{category}.title"),
                checked: security || prefs.dig("notification_types", category) == true,
                disabled: security,
                hidden_value: (security ? "true" : nil),
                help: (security ? t("notifications.preferences.notification_types.always_on") : nil) %>
        <% end %>
      <% end %>
      <%= render "shared/preferences_row",
            icon_name: type_icons[category][:name],
            icon_color: type_icons[category][:color],
            title: t("notifications.preferences.notification_types.items.#{category}.title"),
            description: t("notifications.preferences.notification_types.items.#{category}.description"),
            control: type_control %>
    <% end %>
  <% end %>

  <%# === Card 2: Delivery Method ===================================
      2 rows: in_app (toggle) and email (toggle + frequency select).
      Each control gets its own form so auto-submit fires per-change. -%>
  <%= render layout: "shared/preferences_card",
        locals: {
          title: t("notifications.preferences.delivery_methods.heading"),
          description: t("notifications.preferences.delivery_methods.description")
        } do %>
    <% in_app_control = capture do %>
      <%= form_with url: account_notification_preferences_path,
            method: :patch,
            data: { controller: "auto-submit" },
            class: "inline-block" do |f| %>
        <%= render "shared/toggle",
              name: "notification_preferences[delivery_methods][in_app][enabled]",
              label: t("notifications.preferences.delivery_methods.items.in_app.title"),
              checked: prefs.dig("delivery_methods", "in_app", "enabled") == true %>
      <% end %>
    <% end %>
    <%= render "shared/preferences_row",
          icon_name: "computer_desktop",
          icon_color: :info,
          title: t("notifications.preferences.delivery_methods.items.in_app.title"),
          description: t("notifications.preferences.delivery_methods.items.in_app.description"),
          control: in_app_control %>

    <% email_control = capture do %>
      <div class="flex items-center gap-3">
        <%= form_with url: account_notification_preferences_path,
              method: :patch,
              data: { controller: "auto-submit" },
              class: "inline-block" do |f| %>
          <%= render "shared/toggle",
                name: "notification_preferences[delivery_methods][email][enabled]",
                label: t("notifications.preferences.delivery_methods.items.email.title"),
                checked: prefs.dig("delivery_methods", "email", "enabled") == true %>
        <% end %>
        <%= form_with url: account_notification_preferences_path,
              method: :patch,
              data: { controller: "auto-submit" },
              class: "inline-block" do |f| %>
          <label for="email-frequency" class="sr-only">
            <%= t("notifications.preferences.delivery_methods.frequency.label") %>
          </label>
          <select id="email-frequency"
                  name="notification_preferences[delivery_methods][email][frequency]"
                  autocomplete="off"
                  data-action="change->auto-submit#submit"
                  class="min-h-[44px] px-3 rounded-md bg-surface text-text-body border border-border-strong
                         focus:outline-none focus:ring-2 focus:ring-interactive-focus">
            <% NotificationPreferences::EMAIL_FREQUENCIES.each do |freq| %>
              <option value="<%= freq %>"
                      <% if prefs.dig("delivery_methods", "email", "frequency") == freq %>selected<% end %>>
                <%= t("notifications.preferences.delivery_methods.frequency.options.#{freq}") %>
              </option>
            <% end %>
          </select>
        <% end %>
      </div>
    <% end %>
    <%= render "shared/preferences_row",
          icon_name: "envelope",
          icon_color: :info,
          title: t("notifications.preferences.delivery_methods.items.email.title"),
          description: t("notifications.preferences.delivery_methods.items.email.description"),
          control: email_control %>
  <% end %>

  <%# === Card 3: Quiet Hours =======================================
      Custom layout (not _preferences_row): the toggle + time inputs
      + reassurance text flow together as one configuration cluster.
      Security reassurance is FIXED TEXT per spec decision #6 — not a
      toggle, because security always bypasses quiet_hours and a
      toggle without runtime effect would be deceptive UI. -%>
  <%= render layout: "shared/preferences_card",
        locals: {
          title: t("notifications.preferences.quiet_hours.heading"),
          description: t("notifications.preferences.quiet_hours.description")
        } do %>
    <div class="px-6 py-5 space-y-4">
      <%= form_with url: account_notification_preferences_path,
            method: :patch,
            data: { controller: "auto-submit" } do |f| %>
        <%= render "shared/toggle",
              name: "notification_preferences[quiet_hours][enabled]",
              label: t("notifications.preferences.quiet_hours.enabled_label"),
              checked: prefs.dig("quiet_hours", "enabled") == true %>
      <% end %>

      <%= form_with url: account_notification_preferences_path,
            method: :patch,
            data: { controller: "auto-submit" },
            class: "flex flex-wrap gap-4 items-end" do |f| %>
        <div>
          <label for="quiet-hours-start"
                 class="block text-sm font-medium text-text-heading mb-1">
            <%= t("notifications.preferences.quiet_hours.start_label") %>
          </label>
          <input type="time"
                 id="quiet-hours-start"
                 name="notification_preferences[quiet_hours][start]"
                 value="<%= prefs.dig("quiet_hours", "start") || "22:00" %>"
                 autocomplete="off"
                 data-action="change->auto-submit#submit"
                 class="min-h-[44px] px-3 rounded-md bg-surface text-text-body border border-border-strong
                        focus:outline-none focus:ring-2 focus:ring-interactive-focus">
        </div>
        <div>
          <label for="quiet-hours-end"
                 class="block text-sm font-medium text-text-heading mb-1">
            <%= t("notifications.preferences.quiet_hours.end_label") %>
          </label>
          <input type="time"
                 id="quiet-hours-end"
                 name="notification_preferences[quiet_hours][end]"
                 value="<%= prefs.dig("quiet_hours", "end") || "07:00" %>"
                 autocomplete="off"
                 data-action="change->auto-submit#submit"
                 class="min-h-[44px] px-3 rounded-md bg-surface text-text-body border border-border-strong
                        focus:outline-none focus:ring-2 focus:ring-interactive-focus">
        </div>
      <% end %>

      <p class="text-xs text-text-muted">
        <%= t("notifications.preferences.quiet_hours.security_reassurance") %>
      </p>
    </div>
  <% end %>

  <%# === Card 4: Advanced ==========================================
      Retention dropdown only. Future Phase 3 sounds/desktop-notif
      toggles will land here too. -%>
  <%= render layout: "shared/preferences_card",
        locals: { title: t("notifications.preferences.advanced.heading") } do %>
    <div class="px-6 py-5 space-y-2">
      <%= form_with url: account_notification_preferences_path,
            method: :patch,
            data: { controller: "auto-submit" },
            class: "flex flex-wrap items-center gap-3" do |f| %>
        <label for="retention-days"
               class="text-sm text-text-body">
          <%= t("notifications.preferences.advanced.retention_label") %>
        </label>
        <select id="retention-days"
                name="notification_preferences[retention_days]"
                autocomplete="off"
                data-action="change->auto-submit#submit"
                class="min-h-[44px] px-3 rounded-md bg-surface text-text-body border border-border-strong
                       focus:outline-none focus:ring-2 focus:ring-interactive-focus">
          <% [ 30, 60, 90, 180, 365 ].each do |days| %>
            <option value="<%= days %>"
                    <% if prefs_object.retention_days == days %>selected<% end %>>
              <%= t("notifications.preferences.advanced.retention_options.#{days}") %>
            </option>
          <% end %>
          <option value=""
                  <% if prefs_object.retention_days.nil? %>selected<% end %>>
            <%= t("notifications.preferences.advanced.retention_options.never") %>
          </option>
        </select>
      <% end %>
      <p class="text-xs text-text-muted">
        <%= t("notifications.preferences.advanced.retention_help") %>
      </p>
    </div>
  <% end %>
</section>
