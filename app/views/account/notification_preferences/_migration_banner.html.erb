<%# Migration banner — surfaces once after the v2 IA shift lands so existing
    users notice the change without being nagged on unrelated pages. Dismiss
    writes `dismissed_notifications_redesign_banner_at` and Turbo replaces
    this frame with an empty one, so the banner vanishes without a full
    page reload. -%>
<%= turbo_frame_tag "notifications_redesign_banner" do %>
  <div class="rounded-lg bg-info-surface border border-info text-info
              flex items-start gap-3 px-4 py-3 mb-2">
    <%= icon(:information_circle, size: :sm, class: "shrink-0 mt-0.5") %>
    <p class="flex-1 text-sm">
      <%= t("notifications.preferences.migration_banner.message") %>
    </p>
    <%= button_to dismiss_banner_account_notification_preferences_path,
          method: :post,
          form: { data: { turbo_frame: "notifications_redesign_banner" } },
          aria: { label: t("notifications.preferences.migration_banner.dismiss_aria") },
          class: "shrink-0 text-sm text-info underline
                  hover:text-info/80
                  focus:outline-none focus:ring-2 focus:ring-interactive-focus
                  min-h-[var(--form-input-height)] px-2 rounded bg-transparent border-0 cursor-pointer" do %>
      <%= t("notifications.preferences.migration_banner.dismiss") %>
    <% end %>
  </div>
<% end %>
