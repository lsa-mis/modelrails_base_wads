<% content_for(:title) { t("settings.pages.appearance.h1") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <%= render "shared/settings_page_header",
        title: t("settings.pages.appearance.h1"),
        description: t("settings.pages.appearance.description") %>

  <%# Theme toggle reuses shared/_theme_toggle (the same control mounted
      in the header user menu). The :labeled style surfaces the current
      mode name inline so this destination is meaningful on its own. %>
  <div class="mt-6">
    <%= render "shared/theme_toggle", style: :labeled %>
  </div>
</div>
