<% content_for(:title) { t("account.passwords.new.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-text-heading">
    <%= t("account.passwords.new.title") %>
  </h1>

  <p class="mt-2 text-text-muted">
    <%= t("account.passwords.new.instructions") %>
  </p>

  <%= form_with url: account_password_path, method: :post, class: "mt-8 space-y-6" do |form| %>
    <% if Current.user.errors.any? %>
      <div role="alert" class="p-4 bg-danger-surface rounded-lg">
        <ul class="list-disc list-inside text-danger">
          <% Current.user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :password, t("account.passwords.new.password_label"),
            class: "block text-sm font-medium text-text-body" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password",
            name: "user[password]",
            aria: { describedby: "password-requirements" },
            class: "mt-1 block w-full rounded-md border border-border-strong
                    bg-surface-raised px-3 py-2
                    text-text-heading
                    focus:outline-none focus:ring-2 focus:ring-interactive-focus focus:border-interactive-focus" %>
      <p id="password-requirements" class="mt-1 text-sm text-text-muted">
        <%= t("account.passwords.new.password_hint") %>
      </p>
    </div>

    <div>
      <%= form.label :password_confirmation, t("account.passwords.new.password_confirmation_label"),
            class: "block text-sm font-medium text-text-body" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password",
            name: "user[password_confirmation]",
            class: "mt-1 block w-full rounded-md border border-border-strong
                    bg-surface-raised px-3 py-2
                    text-text-heading
                    focus:outline-none focus:ring-2 focus:ring-interactive-focus focus:border-interactive-focus" %>
    </div>

    <%= form.submit t("account.passwords.new.submit"),
          class: "w-full min-h-[44px] rounded-md px-4 py-2
                  bg-interactive hover:bg-interactive-hover text-text-on-interactive font-medium
                  focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-interactive-focus
                  cursor-pointer" %>
  <% end %>
</div>
