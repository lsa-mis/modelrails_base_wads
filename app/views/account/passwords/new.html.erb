<% content_for(:title) { t("account.passwords.new.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-text-heading">
    <%= t("account.passwords.new.title") %>
  </h1>

  <p class="mt-2 text-text-muted">
    <%= t("account.passwords.new.instructions") %>
  </p>

  <%= form_with model: Current.user, url: account_password_path, method: :post, class: "mt-8 space-y-6" do |form| %>
    <%= form.error_summary %>

    <%= form.password_field :password,
          label: t("account.passwords.new.password_label"),
          required: true,
          autocomplete: "new-password",
          help: t("account.passwords.new.password_hint") %>

    <%= form.password_field :password_confirmation,
          label: t("account.passwords.new.password_confirmation_label"),
          required: true,
          autocomplete: "new-password" %>

    <%= form.submit t("account.passwords.new.submit"), class: "w-full" %>
  <% end %>
</div>
