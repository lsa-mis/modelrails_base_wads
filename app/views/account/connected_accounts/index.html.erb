<% content_for(:title) { t("account.connected_accounts.index.title") } %>
<div class="max-w-2xl mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-text-heading">
    <%= t("account.connected_accounts.index.title") %>
  </h1>

  <% if (auth_id = flash[:confirming_email_for]) && (pending = @authentications.find { |a| a.id == auth_id }) %>
    <div class="mt-6 rounded-lg border border-info-border bg-info-surface p-4 text-sm text-info" role="status" aria-live="polite" aria-atomic="true">
      <%= t("account.connected_accounts.index.confirming_banner_html", email: pending.email, provider: pending.display_provider) %>
    </div>
  <% end %>

  <ul role="list" class="mt-8 space-y-4">
    <% @authentications.each do |authentication| %>
      <li class="flex items-center justify-between p-4 border rounded-lg <%= authentication.pending? ? "bg-info-surface border-info-border" : "border-border" %>">
        <div>
          <p class="font-medium text-text-heading">
            <%= authentication.display_provider %>
            <span class="sr-only">
              <%= authentication.pending? ? t("account.connected_accounts.index.pending_state_sr") : t("account.connected_accounts.index.verified_state_sr") %>
            </span>
          </p>
          <% if authentication.pending? %>
            <p class="text-xs text-info">
              <%= t("account.connected_accounts.index.pending_label", email: authentication.email) %>
            </p>
            <p class="text-xs text-text-muted mt-1">
              <%= t("account.connected_accounts.index.pending_help") %>
            </p>
          <% else %>
            <p class="text-sm text-text-muted">
              <%= authentication.email? ? t("account.connected_accounts.index.email_provider") : (authentication.email.presence || authentication.uid) %>
            </p>
            <% if authentication.verified? %>
              <span class="inline-flex items-center px-2.5 py-1 rounded bg-success-surface text-xs font-medium text-success">
                <%= t("account.connected_accounts.index.verified") %>
              </span>
            <% end %>
          <% end %>
        </div>

        <div class="flex items-center gap-3 text-sm">
          <% if authentication.pending? %>
            <%= button_to t("account.connected_accounts.index.resend_action"),
                  resend_verification_account_connected_account_path(authentication),
                  method: :post,
                  aria: { label: t("account.connected_accounts.index.resend_action_aria_label", provider: authentication.display_provider) },
                  class: "text-sm text-interactive underline hover:no-underline
                          focus:outline-none focus:ring-2 focus:ring-interactive-focus rounded
                          min-h-[44px] min-w-[44px] inline-flex items-center justify-center px-2",
                  form: { class: "inline" } %>
            <%= button_to t("account.connected_accounts.index.cancel_action"),
                  account_connected_account_path(authentication),
                  method: :delete,
                  aria: { label: t("account.connected_accounts.index.cancel_action_aria_label", provider: authentication.display_provider) },
                  class: "text-sm font-medium text-danger underline hover:no-underline
                          focus:outline-none focus:ring-2 focus:ring-danger rounded
                          min-h-[44px] min-w-[44px] inline-flex items-center justify-center px-2",
                  form: { class: "inline" } %>
          <% else %>
            <div data-controller="modal" class="inline">
              <button type="button"
                      data-action="click->modal#open"
                      aria-label="<%= t("account.connected_accounts.index.disconnect_action_aria_label", provider: authentication.display_provider) %>"
                      class="text-sm font-medium text-danger underline hover:no-underline
                             focus:outline-none focus:ring-2 focus:ring-danger rounded
                             min-h-[44px] min-w-[44px] inline-flex items-center justify-center px-2">
                <%= t("account.connected_accounts.index.disconnect") %>
              </button>

              <%= render "shared/confirm_dialog",
                    title: t("account.connected_accounts.index.disconnect_title", provider: authentication.display_provider),
                    message: t("account.connected_accounts.index.disconnect_message", provider: authentication.display_provider, email: authentication.email),
                    confirm_text: t("account.connected_accounts.index.disconnect"),
                    confirm_url: account_connected_account_path(authentication),
                    confirm_method: :delete,
                    variant: :danger %>
            </div>
          <% end %>
        </div>
      </li>
    <% end %>
  </ul>
</div>
