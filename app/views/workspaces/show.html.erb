<% content_for(:title) { @workspace.name } %>
<div class="max-w-4xl mx-auto px-4 py-16">
  <%= turbo_stream_from @workspace %>
  <div class="flex items-center gap-4">
    <% if @workspace.logo.attached? %>
      <%= image_tag @workspace.logo, class: "w-16 h-16 rounded-full object-cover" %>
    <% else %>
      <div class="w-16 h-16 rounded-full bg-sky-100 dark:bg-sky-900 flex items-center justify-center text-sky-700 dark:text-sky-300 font-bold text-xl">
        <%= @workspace.initials %>
      </div>
    <% end %>
    <div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-gray-100">
        <%= @workspace.name %>
      </h1>
      <p class="text-sm text-slate-600 dark:text-gray-400"><%= @workspace.plan.titleize %></p>
    </div>
  </div>

  <%= render "shared/activity_feed", activities: ActivityLog.visible.for_workspace(@workspace).recent.includes(:actor) %>
</div>
