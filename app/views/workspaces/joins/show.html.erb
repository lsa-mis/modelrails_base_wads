<% content_for(:title) { t("workspaces.joins.show.title", workspace: @workspace.name) } %>

<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-text-heading">
    <%= t("workspaces.joins.show.title", workspace: @workspace.name) %>
  </h1>

  <p class="mt-4 text-text">
    <%= t("workspaces.joins.show.prompt", workspace: @workspace.name) %>
  </p>

  <div class="mt-8 flex items-center gap-3">
    <%= button_to t("workspaces.joins.show.join_button", workspace: @workspace.name),
          workspace_join_path(@workspace, token: @link.token),
          method: :post,
          class: "btn-primary" %>

    <%= link_to t("workspaces.joins.show.cancel"), root_path,
          class: "btn-touch-target inline-flex items-center px-4 py-2 rounded-md
                  text-sm font-medium text-text-muted hover:bg-surface-sunken
                  focus-ring" %>
  </div>
</div>
