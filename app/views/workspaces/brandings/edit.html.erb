<% content_for(:title) { t("workspaces.brandings.edit.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-gray-100">
    <%= t("workspaces.brandings.edit.title") %>
  </h1>

  <%= form_with model: @workspace, url: workspace_branding_path(@workspace), method: :patch,
        class: "mt-8 space-y-6", data: { controller: "color-picker" } do |form| %>
    <div>
      <p class="block text-sm font-medium text-slate-700 dark:text-gray-300 mb-2">
        <%= t("workspaces.brandings.edit.logo_label") %>
      </p>
      <div class="flex items-center gap-4">
        <% if @workspace.logo.attached? %>
          <%= image_tag @workspace.logo, class: "w-16 h-16 rounded-full object-cover" %>
        <% else %>
          <div class="w-16 h-16 rounded-full bg-sky-100 dark:bg-sky-900 flex items-center justify-center text-sky-700 dark:text-sky-300 font-bold text-xl">
            <%= @workspace.initials %>
          </div>
        <% end %>
        <%= form.file_field :logo, accept: "image/*",
              class: "text-sm text-slate-600 dark:text-gray-400" %>
      </div>
    </div>

    <div>
      <%= form.label :primary_color, t("workspaces.brandings.edit.color_label"),
            class: "block text-sm font-medium text-slate-700 dark:text-gray-300" %>
      <%= form.text_field :primary_color,
            value: @workspace.primary_color || "oklch(0.55 0.18 233)",
            data: { color_picker_target: "input", action: "input->color-picker#update" },
            class: "mt-1 block w-full rounded-md border border-gray-300 dark:border-gray-600
                    bg-white dark:bg-gray-800 px-3 py-2
                    text-slate-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-sky-700 focus:border-sky-700" %>
      <p class="mt-1 text-sm text-slate-600 dark:text-gray-400">
        <%= t("workspaces.brandings.edit.color_hint") %>
      </p>
    </div>

    <div data-color-picker-target="preview"
         style="--ws-primary: <%= @workspace.primary_color || 'oklch(0.55 0.18 233)' %>"
         class="p-4 rounded-lg border border-gray-200 dark:border-gray-700">
      <p class="text-sm text-slate-600 dark:text-gray-400"><%= t("workspaces.brandings.edit.preview") %></p>
      <div class="mt-2 h-8 rounded" style="background: var(--ws-primary);"></div>
    </div>

    <%= form.submit t("workspaces.brandings.edit.submit"),
          class: "w-full min-h-[44px] rounded-md px-4 py-2
                  bg-sky-700 hover:bg-sky-800 text-white font-medium
                  focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-sky-700
                  cursor-pointer" %>
  <% end %>
</div>
