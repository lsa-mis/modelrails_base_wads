<% content_for(:title) { t("workspaces.brandings.crop.title") } %>
<%
  existing_crop = @workspace.logo.blob.metadata["crop"] || {}
%>

<div data-controller="modal"
     data-action="keydown.esc@document->modal#handleEscOnPage">

  <%= render "shared/image_crop",
        image: @workspace.logo,
        aspect_ratio: 1.0,
        shape: :circle,
        save_url: save_crop_workspace_branding_path(@workspace),
        cancel_url: edit_workspace_branding_path(@workspace),
        upload_action: "click->modal#open",
        remove_url: workspace_branding_path(@workspace),
        remove_method: :patch,
        existing_crop: existing_crop,
        title: t("workspaces.brandings.crop.title") %>

  <%= render "shared/image_upload_modal",
        title: t("workspaces.brandings.edit.change_logo"),
        form_url: workspace_branding_path(@workspace),
        field_name: :logo,
        auto_submit: true,
        redirect_on_submit: true %>
</div>
