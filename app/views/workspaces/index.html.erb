<% content_for(:title) { t("workspaces.index.title") } %>
<div class="max-w-4xl mx-auto px-4 py-16">
  <div class="flex items-center justify-between">
    <h1 class="text-3xl font-bold text-text-heading">
      <%= t("workspaces.index.title") %>
    </h1>
    <% if TenancyConfig.workspace_creation_enabled? %>
      <%= link_to t("workspaces.index.new_workspace"), new_workspace_path,
            class: "btn-primary" %>
    <% end %>
  </div>

  <% if @current_membership.present? %>
    <section class="mt-8" data-test="current-workspace-row" aria-label="<%= t('workspaces.index.current_badge') %>">
      <ul class="flex flex-col gap-2">
        <%= render "workspaces/row", membership: @current_membership, current: true %>
      </ul>
    </section>
  <% end %>

  <% if @other_memberships.any? %>
    <section class="mt-8">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-3">
        <%= t("workspaces.index.other_workspaces_heading") %>
      </h2>
      <ul class="flex flex-col gap-2" data-test="other-workspaces-list">
        <% @other_memberships.each do |membership| %>
          <%= render "workspaces/row", membership: membership, current: false %>
        <% end %>
      </ul>
    </section>
  <% end %>

  <% if @archived_memberships.any? %>
    <section class="mt-8" data-test="archived-workspaces">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-3">
        <%= t("workspaces.index.archived_heading") %>
      </h2>
      <ul class="flex flex-col gap-2">
        <% @archived_memberships.each do |membership| %>
          <li class="flex items-center justify-between gap-4 p-4 border border-border rounded-lg bg-surface">
            <div class="min-w-0">
              <p class="font-medium text-text-heading truncate"><%= membership.workspace.name %></p>
              <p class="text-sm text-text-muted"><%= lifecycle_status_label(membership.workspace) %></p>
            </div>
            <%= button_to t("lifecycle.restore"), unarchive_workspace_path(membership.workspace),
                  method: :patch,
                  class: "btn-touch-target btn-text btn-text-interactive text-sm shrink-0" %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <% if @memberships.empty? && @archived_memberships.empty? %>
    <div class="mt-8">
      <%= render "shared/empty_state",
            message: t("workspaces.index.empty"),
            action_text: TenancyConfig.workspace_creation_enabled? ? t("workspaces.index.new_workspace") : nil,
            action_url: TenancyConfig.workspace_creation_enabled? ? new_workspace_path : nil %>
    </div>
  <% end %>

  <% if TenancyConfig.workspace_creation_enabled? %>
    <div class="mt-12 text-center">
      <%= link_to t("workspaces.index.create_workspace_cta"), new_workspace_path,
            class: "btn-touch-target inline-flex items-center px-4 py-2 rounded-md
                    text-sm font-medium text-interactive
                    hover:bg-surface-sunken
                    focus-ring" %>
    </div>
  <% end %>
</div>
