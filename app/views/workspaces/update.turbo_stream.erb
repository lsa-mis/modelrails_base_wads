<%# Replace the workspace name heading in the persistent identity bar when
    renamed in-context — shares shared/_workspace_name_link with
    shared/_workspace_identity_bar so the two can't drift. %>
<%= turbo_stream.replace "workspace-name-heading" do %>
  <%= render "shared/workspace_name_link", workspace: @workspace %>
<% end %>

<%= turbo_stream.replace "workspace_logo_branding" do %>
  <span id="workspace_logo_branding" class="block relative">
    <%= workspace_icon_for(@workspace, size: :lg) %>
    <span class="absolute inset-0 rounded-full bg-black/0 group-hover:bg-black/20
                 transition-colors flex items-center justify-center">
      <%= icon(:pencil, size: :sm,
            class: "text-white opacity-0 group-hover:opacity-100 transition-opacity drop-shadow-md") %>
    </span>
  </span>
<% end %>

<%= turbo_stream.replace "workspace_logo_show" do %>
  <span id="workspace_logo_show" class="shrink-0">
    <%= workspace_icon_for(@workspace, size: :md) %>
  </span>
<% end %>

<% if @close_modal %>
  <%# Close any open modal that targets the standard "modal-body" slot (settings edit page). %>
  <%= turbo_stream.append "modal-body" do %>
    <div data-controller="modal-closer"></div>
  <% end %>
  <%# Close the Customize modal on the personal-workspace Overview (uses a stable id). %>
  <%= turbo_stream.append "workspace-customize-body" do %>
    <div data-controller="modal-closer"></div>
  <% end %>
<% end %>

<%= turbo_stream.append "toast-pills" do %>
  <%= render "shared/toast_pill", type: :success, message: t("workspaces.update.success") %>
<% end %>
