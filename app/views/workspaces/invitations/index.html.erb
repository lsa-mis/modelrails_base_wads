<% content_for(:title) { t("workspaces.invitations.index.title") } %>
<div class="max-w-4xl mx-auto px-4 py-16">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-text-heading">
      <%= t("workspaces.invitations.index.title") %>
    </h1>
    <% if policy(Invitation).create? %>
      <%= link_to t("workspaces.invitations.index.new_invitation"), new_workspace_invitation_path(@workspace),
            class: "min-h-[44px] flex items-center px-4 rounded-md
                    bg-interactive hover:bg-interactive-hover text-text-on-interactive font-medium
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-interactive-focus" %>
    <% end %>
  </div>

  <% if flash[:magic_link_url].present? %>
    <div class="mt-4 p-4 bg-info-surface rounded-lg" role="alert">
      <p class="text-sm font-medium text-interactive">
        <%= t("workspaces.invitations.index.magic_link_label") %>
      </p>
      <code class="mt-1 block text-sm text-interactive break-all">
        <%= flash[:magic_link_url] %>
      </code>
    </div>
  <% end %>

  <table class="mt-8 w-full">
    <thead>
      <tr class="border-b border-border">
        <th scope="col" class="text-left py-3 text-sm font-medium text-text-muted"><%= t("workspaces.invitations.index.invitee") %></th>
        <th scope="col" class="text-left py-3 text-sm font-medium text-text-muted"><%= t("workspaces.invitations.index.role") %></th>
        <th scope="col" class="text-left py-3 text-sm font-medium text-text-muted"><%= t("workspaces.invitations.index.status") %></th>
        <th scope="col" class="text-left py-3 text-sm font-medium text-text-muted"><%= t("workspaces.invitations.index.actions") %></th>
      </tr>
    </thead>
    <tbody>
      <% @invitations.each do |invitation| %>
        <tr class="border-b border-border">
          <td class="py-3 text-text-heading">
            <%= invitation.magic_link? ? t("workspaces.invitations.index.magic_link") : invitation.email %>
          </td>
          <td class="py-3 text-text-muted"><%= invitation.role.name %></td>
          <td class="py-3">
            <span class="px-2 py-1 text-xs font-medium rounded-full
                         <%= invitation.pending? ? 'bg-warning-surface text-warning' :
                             invitation.accepted? ? 'bg-success-surface text-success' :
                             'bg-surface text-text-muted' %>">
              <%= invitation.status.titleize %>
            </span>
          </td>
          <td class="py-3">
            <% if invitation.pending? && policy(invitation).destroy? %>
              <div class="flex gap-2">
                <%= button_to t("workspaces.invitations.index.resend"),
                      resend_workspace_invitation_path(@workspace, invitation),
                      method: :post,
                      class: "text-sm text-interactive underline hover:no-underline cursor-pointer" %>
                <%= button_to t("workspaces.invitations.index.revoke"),
                      workspace_invitation_path(@workspace, invitation),
                      method: :delete,
                      class: "text-sm text-danger underline hover:no-underline cursor-pointer" %>
              </div>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
