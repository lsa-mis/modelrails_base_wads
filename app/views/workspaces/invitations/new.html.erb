<% content_for(:title) { t("workspaces.invitations.new.title") } %>
<div class="max-w-2xl px-6 pt-4 pb-16">
  <h1 class="text-2xl font-semibold text-text-heading">
    <%= t("workspaces.invitations.new.title") %>
  </h1>

  <%= form_with model: @invitation, url: workspace_invitations_path(@workspace), class: "mt-8 space-y-6" do |form| %>
    <%= form.text_area :emails,
          label: t("workspaces.invitations.new.emails_label"),
          help: t("workspaces.invitations.new.emails_hint"),
          rows: 4 %>

    <%= form.select :role_id,
          @roles.map { |r| [r.name, r.id] },
          { label: t("workspaces.invitations.new.role_label") },
          {} %>

    <%= form.submit t("workspaces.invitations.new.submit"), class: "btn-primary" %>
  <% end %>
</div>
