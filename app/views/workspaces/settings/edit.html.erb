<% content_for(:title) { t("workspaces.settings.edit.title") } %>
<%# Workspace Limits & Plan — operational config (capacity, plan).
    Identity (name, logo, primary_color) lives on WorkspacesController#edit. %>
<div class="max-w-2xl mx-auto px-4 py-16">
  <%= render "shared/settings_page_header",
        title_html: t("settings.pages.workspace_limits_and_plan.h1_html", name: ERB::Util.html_escape(@workspace.name)),
        description: t("settings.pages.workspace_limits_and_plan.description") %>

  <div class="mt-8">
    <%= render "workspaces/settings/capacity_section", workspace: @workspace %>
  </div>
</div>
