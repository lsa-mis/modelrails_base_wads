<% content_for(:title) { t("workspaces.settings.edit.title") } %>
<%# Workspace Limits & Plan — operational config (capacity, plan).
    Identity (name, logo, primary_color) lives on WorkspacesController#edit. %>
<div class="max-w-2xl px-6 pt-4 pb-16">
  <% if @workspace.archived? %>
    <%= render "shared/archived_banner",
          message: t("workspaces.archived_banner"),
          restore_path: unarchive_workspace_path(@workspace) %>
  <% end %>
  <%= render "shared/settings_page_header",
        title_html: t("settings.pages.workspace_limits_and_plan.h1_html"),
        description: t("settings.pages.workspace_limits_and_plan.description") %>

  <div class="mt-8">
    <%= render "workspaces/settings/capacity_section", workspace: @workspace %>
  </div>

  <% unless TenancyConfig.shared? %>
    <div class="mt-8">
      <%= render "workspaces/settings/join_policy_section", workspace: @workspace %>
    </div>
  <% end %>

  <% if policy(@workspace).destroy? %>
    <div class="mt-8">
      <%= render "workspaces/settings/danger_zone_section", workspace: @workspace %>
    </div>
  <% end %>
</div>
