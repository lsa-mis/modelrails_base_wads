<%# Join Policy — per-workspace control over how new members join. Hidden
    under :shared posture (no separate join story in single-tenant). %>
<% open_link_permitted = SignupPolicy.permits_strategy?(:open_link) %>
<% active_link = workspace.join_links.active.order(created_at: :desc).first %>

<section class="rounded-lg border border-border bg-surface p-6">
  <h2 class="text-lg font-semibold text-text-heading">
    <%= t("workspaces.settings.join_policy.heading") %>
  </h2>
  <p class="mt-1 text-sm text-text-muted">
    <%= t("workspaces.settings.join_policy.description") %>
  </p>

  <%= form_with model: workspace, url: workspace_settings_path(workspace), method: :patch, local: true, class: "mt-4 space-y-3" do |f| %>
    <div class="flex items-start gap-2">
      <%= f.radio_button :join_policy, "invite", id: "join_policy_invite",
            class: "mt-1 focus-ring" %>
      <label for="join_policy_invite" class="text-sm">
        <span class="font-medium"><%= t("workspaces.settings.join_policy.invite_label") %></span>
        <span class="block text-text-muted"><%= t("workspaces.settings.join_policy.invite_help") %></span>
      </label>
    </div>

    <div class="flex items-start gap-2">
      <%= f.radio_button :join_policy, "open_link", id: "join_policy_open_link",
            disabled: !open_link_permitted,
            class: "mt-1 focus-ring" %>
      <label for="join_policy_open_link" class="text-sm <%= "opacity-60" unless open_link_permitted %>">
        <span class="font-medium"><%= t("workspaces.settings.join_policy.open_link_label") %></span>
        <span class="block text-text-muted">
          <%= t("workspaces.settings.join_policy.open_link_help") %>
        </span>
        <% unless open_link_permitted %>
          <span class="block mt-1 text-text-muted italic">
            <%= t("workspaces.settings.join_policy.open_link_disabled_explanation") %>
          </span>
        <% end %>
      </label>
    </div>

    <div class="pt-2">
      <%= f.submit t("workspaces.settings.join_policy.save"),
            class: "btn-primary" %>
    </div>
  <% end %>

  <% if workspace.open_link? && open_link_permitted %>
    <div class="mt-6 pt-6 border-t border-border" data-controller="clipboard">
      <h3 class="text-sm font-semibold text-text-heading">
        <%= t("workspaces.settings.join_policy.active_link_heading") %>
      </h3>

      <% if active_link %>
        <% join_url = workspace_join_url(workspace, token: active_link.token) %>
        <div class="mt-2 flex items-center gap-2">
          <input type="text"
                 readonly
                 value="<%= join_url %>"
                 autocomplete="off"
                 data-clipboard-target="source"
                 class="flex-1 min-w-0 text-sm font-mono px-3 py-2 rounded-md border border-border bg-surface-sunken text-text"
                 aria-label="<%= t('workspaces.settings.join_policy.link_aria') %>">
          <button type="button"
                  data-action="clipboard#copy"
                  class="btn-touch-target inline-flex items-center px-3 py-2 rounded-md text-sm
                         border border-border hover:bg-surface-sunken
                         focus-ring">
            <span data-clipboard-target="label"><%= t("workspaces.settings.join_policy.copy") %></span>
          </button>
        </div>

        <p role="status" aria-live="polite" data-clipboard-target="status" class="mt-1 text-xs text-text-muted h-4"></p>

        <div class="mt-4 flex items-center gap-3">
          <%= button_to t("workspaces.settings.join_policy.rotate"),
                workspace_join_links_path(workspace),
                method: :post,
                form: { data: { turbo_confirm: t("workspaces.settings.join_policy.rotate_confirm") } },
                class: "btn-touch-target inline-flex items-center px-3 py-2 rounded-md text-sm
                        border border-border hover:bg-surface-sunken
                        focus-ring" %>

          <%= button_to t("workspaces.settings.join_policy.revoke"),
                workspace_join_link_path(workspace, active_link),
                method: :delete,
                form: { data: { turbo_confirm: t("workspaces.settings.join_policy.revoke_confirm") } },
                class: "btn-touch-target inline-flex items-center px-3 py-2 rounded-md text-sm
                        text-danger border border-danger-border hover:bg-danger-surface
                        focus-ring" %>
        </div>
      <% else %>
        <p class="mt-2 text-sm text-text-muted">
          <%= t("workspaces.settings.join_policy.no_active_link") %>
        </p>
        <div class="mt-3">
          <%= button_to t("workspaces.settings.join_policy.generate"),
                workspace_join_links_path(workspace),
                method: :post,
                class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
