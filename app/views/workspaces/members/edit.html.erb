<% content_for(:title) { t("workspaces.members.edit.title") } %>
<%# When loaded as a Turbo Frame target from the members index, Turbo extracts
    just the matching <turbo-frame> below and replaces it inline. Non-Turbo
    requests get the full standalone page wrapper. %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-3xl font-bold text-text-heading">
    <%= t("workspaces.members.edit.title") %>
  </h1>

  <p class="mt-2 text-text-muted">
    <%= @membership.user.full_name %> (<%= @membership.user.email_address %>)
  </p>

  <div class="mt-8">
    <%= turbo_frame_tag dom_id(@membership, :role) do %>
      <%= form_with model: @membership, url: workspace_member_path(@workspace, @membership),
            method: :patch, class: "flex items-end gap-3" do |form| %>
        <div class="flex-1">
          <%# autofocus: the user just clicked "Edit role" specifically to
              edit, so focusing the select on frame-load matches intent
              (not the "unexpected focus jump" the a11y-no-autofocus rule
              guards against). %>
          <%= form.select :role_id,
                @roles.map { |r| [r.name, r.id] },
                { label: t("workspaces.members.edit.role_label"), selected: @membership.role_id },
                { autofocus: true } %>
        </div>

        <%= form.submit t("workspaces.members.edit.submit"), class: "btn-primary" %>
      <% end %>
    <% end %>
  </div>
</div>
