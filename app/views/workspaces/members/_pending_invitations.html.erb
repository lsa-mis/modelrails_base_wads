<%# locals: (workspace:, pending_invitations:) %>
<% if pending_invitations.any? %>
  <section class="mt-10" aria-labelledby="pending-invitations-heading">
    <h2 id="pending-invitations-heading" class="text-lg font-semibold text-text-heading">
      <%= t("workspaces.members.index.pending_invitations.title") %>
    </h2>

    <div class="mt-4 bg-surface-raised rounded-lg border border-border shadow-sm overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-border bg-surface">
            <th scope="col" class="text-left py-3 px-2 text-sm font-medium text-text-muted">
              <%= t("workspaces.members.index.pending_invitations.invitee") %>
            </th>
            <th scope="col" class="text-left py-3 px-2 text-sm font-medium text-text-muted">
              <%= t("workspaces.members.index.pending_invitations.role") %>
            </th>
            <th scope="col" class="text-left py-3 px-2 text-sm font-medium text-text-muted">
              <%= t("workspaces.members.index.pending_invitations.status") %>
            </th>
            <th scope="col" class="text-left py-3 px-2 text-sm font-medium text-text-muted">
              <%= t("workspaces.members.index.pending_invitations.actions") %>
            </th>
          </tr>
        </thead>
        <tbody>
          <% pending_invitations.each do |invitation| %>
            <%= render "workspaces/members/invitation_row",
                  workspace: workspace,
                  invitation: invitation %>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>
