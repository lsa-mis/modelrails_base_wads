<%# locals: (membership:, workspace:) %>
<tr id="<%= dom_id(membership) %>" class="border-b border-border hover:bg-surface-sunken transition-colors">
  <td class="py-3 px-2 text-text-heading"><%= membership.user.full_name %></td>
  <td class="py-3 px-2 text-text-muted"><%= membership.user.email_address %></td>
  <td class="py-3 px-2 text-text-muted"><%= membership.role.name %></td>
  <td class="py-3 px-2">
    <% if membership.discarded? %>
      <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-danger-surface text-danger dark:text-danger-strong">
        <%= t("workspaces.members.index.deactivated") %>
      </span>
    <% else %>
      <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-success-surface text-success">
        <%= t("workspaces.members.index.active") %>
      </span>
    <% end %>
  </td>
  <td class="py-3 px-2 space-x-2">
    <% if policy(membership).update? %>
      <%= link_to t("workspaces.members.index.edit_role"),
            edit_workspace_member_path(workspace, membership),
            class: "text-sm text-interactive hover:text-interactive-hover
                    focus:outline-none focus:ring-2 focus:ring-interactive-focus rounded" %>
    <% end %>
    <% if policy(membership).destroy? && !membership.discarded? %>
      <%= button_to t("workspaces.members.index.deactivate"),
            workspace_member_path(workspace, membership),
            method: :delete,
            class: "text-sm text-danger hover:opacity-80 bg-transparent border-0 cursor-pointer p-0
                    focus:outline-none focus:ring-2 focus:ring-interactive-focus rounded" %>
    <% end %>
    <% if policy(membership).reactivate? && membership.discarded? %>
      <%= button_to t("workspaces.members.index.reactivate"),
            reactivate_workspace_member_path(workspace, membership),
            method: :patch,
            class: "text-sm text-success hover:opacity-80 bg-transparent border-0 cursor-pointer p-0
                    focus:outline-none focus:ring-2 focus:ring-interactive-focus rounded" %>
    <% end %>
    <% if policy(membership).transfer_ownership? %>
      <%= button_to t("workspaces.members.index.transfer_ownership"),
            transfer_ownership_workspace_member_path(workspace, membership),
            method: :patch,
            class: "text-sm text-text-muted hover:text-interactive-hover bg-transparent border-0 cursor-pointer p-0
                    focus:outline-none focus:ring-2 focus:ring-interactive-focus rounded" %>
    <% end %>
  </td>
</tr>
