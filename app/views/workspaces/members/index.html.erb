<% content_for(:title) { t("workspaces.members.index.title") } %>
<div class="max-w-4xl mx-auto px-4 py-16">
  <div class="flex items-start justify-between gap-4">
    <%= render "shared/settings_page_header",
          title_html: t("settings.pages.workspace_members.h1_html", name: ERB::Util.html_escape(@workspace.name)),
          description: t("settings.pages.workspace_members.description") %>
    <% if policy(Invitation).create? %>
      <%= link_to t("workspaces.members.index.invite_member"),
            new_workspace_invitation_path(@workspace),
            class: "btn-primary" %>
    <% end %>
  </div>

  <%= turbo_frame_tag "members_results" do %>
    <%# Filter bar — a plain GET form inside the Turbo Frame %>
    <%= form_with url: workspace_members_path(@workspace),
          method: :get,
          data: { controller: "search-form", turbo_frame: "members_results", turbo_action: "advance" },
          class: "mt-6 flex flex-col gap-3 sm:flex-row sm:items-end" do |form| %>
      <div class="flex-1">
        <%= form.search_field :q,
              label: t("workspaces.members.index.search_placeholder"),
              value: params[:q],
              placeholder: t("workspaces.members.index.search_placeholder"),
              data: { action: "input->search-form#search keydown->search-form#clear" },
              autocomplete: "off" %>
      </div>

      <div class="flex gap-3">
        <%= form.select :role,
              options_for_select(
                [[t("workspaces.members.index.filter_by_role"), ""]] +
                @roles.map { |r| [r.name, r.slug] },
                params[:role]
              ),
              { label: t("workspaces.members.index.filter_by_role") },
              { data: { action: "change->search-form#submit" } } %>

        <%= form.select :status,
              options_for_select(
                [[t("workspaces.members.index.filter_by_status"), ""],
                 [t("workspaces.members.index.status_active"), "active"],
                 [t("workspaces.members.index.status_pending"), "pending"],
                 [t("workspaces.members.index.status_deactivated"), "deactivated"]],
                params[:status]
              ),
              { label: t("workspaces.members.index.filter_by_status") },
              { data: { action: "change->search-form#submit" } } %>
      </div>

      <%# Preserve sort params through filter changes %>
      <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
      <%= hidden_field_tag :direction, params[:direction] if params[:direction].present? %>
    <% end %>

    <%# Live region announces filter changes to assistive tech when the
        Turbo Frame swaps. Count + active filters give SR users the same
        feedback sighted users get from seeing the table update. %>
    <p class="sr-only" role="status" aria-live="polite" aria-atomic="true">
      <%= t("workspaces.members.index.results_summary", count: @pagy.count) %>
    </p>

    <%# Results table — paginated, mixed rows (active members + pending invitations) %>
    <% if @rows.any? %>
      <div class="mt-6 bg-surface-raised rounded-lg border border-border shadow-sm overflow-hidden">
        <table class="w-full" aria-label="<%= t('workspaces.members.index.table_label') %>">
          <thead>
            <tr class="border-b border-border bg-surface">
              <%= render "shared/sortable_header",
                    title: t("workspaces.members.index.name"),
                    column: "name",
                    current_sort: params[:sort],
                    current_direction: params[:direction],
                    url: ->(sort_params) { workspace_members_path(@workspace, request.query_parameters.merge(sort_params)) } %>
              <%= render "shared/sortable_header",
                    title: t("workspaces.members.index.email"),
                    column: "email",
                    current_sort: params[:sort],
                    current_direction: params[:direction],
                    url: ->(sort_params) { workspace_members_path(@workspace, request.query_parameters.merge(sort_params)) } %>
              <%= render "shared/sortable_header",
                    title: t("workspaces.members.index.role"),
                    column: "role",
                    current_sort: params[:sort],
                    current_direction: params[:direction],
                    url: ->(sort_params) { workspace_members_path(@workspace, request.query_parameters.merge(sort_params)) } %>
              <th scope="col" class="text-left py-3 px-2 text-sm font-medium text-text-muted">
                <%= t("workspaces.members.index.status") %>
              </th>
              <th scope="col" class="text-left py-3 px-2 text-sm font-medium text-text-muted">
                <%= t("workspaces.members.index.actions") %>
              </th>
            </tr>
          </thead>
          <tbody>
            <%# Rows are a mix of Membership and Invitation, pre-paginated by
                the controller via pagy(:array, combined). Type detection picks
                the right partial. %>
            <% @rows.each do |row| %>
              <% if row.is_a?(Invitation) %>
                <%= render "workspaces/members/invitation_row", workspace: @workspace, invitation: row %>
              <% else %>
                <%= render "workspaces/members/member_row", membership: row, workspace: @workspace %>
              <% end %>
            <% end %>
          </tbody>
        </table>

        <%= render "shared/pagination", pagy: @pagy %>
      </div>
    <% else %>
      <div class="mt-8">
        <%= render "shared/empty_state", message: t("workspaces.members.index.empty") %>
      </div>
    <% end %>
  <% end %>

  <%# Magic-link generation — separate surface from the email invite button
      above (Jason Fried: kill the "one form pretending to be two" pattern). %>
  <% if policy(Invitation).create? && @roles.present? %>
    <%# data-turbo-frame="_top" targets the whole page rather than the
        members_results frame the form sits next to. Without this, Turbo
        would frame the POST response into members_results and silently
        reset filtering/pagination on submit. %>
    <%= form_with model: Invitation.new, url: workspace_invitations_path(@workspace),
          method: :post, data: { turbo_frame: "_top" },
          class: "mt-8 p-4 bg-surface-sunken rounded-lg" do |form| %>
      <%= form.hidden_field :magic_link, value: "1" %>
      <h2 class="text-base font-semibold text-text-heading">
        <%= t("workspaces.invitations.index.magic_link_section_title") %>
      </h2>
      <p class="mt-1 text-sm text-text-muted">
        <%= t("workspaces.invitations.index.magic_link_section_hint") %>
      </p>
      <div class="mt-3 flex items-end gap-3">
        <div class="flex-1">
          <%= form.select :role_id,
                @roles.map { |r| [r.name, r.id] },
                { label: t("workspaces.invitations.index.magic_link_role_label") },
                {} %>
        </div>
        <%= form.submit t("workspaces.invitations.index.generate_magic_link"),
              class: "btn-primary" %>
      </div>
    <% end %>
  <% end %>

  <% if flash[:magic_link_url].present? %>
    <div class="mt-4 p-4 bg-info-surface rounded-lg" role="alert">
      <p class="text-sm font-medium text-interactive">
        <%= t("workspaces.invitations.index.magic_link_label") %>
      </p>
      <code class="mt-1 block text-sm text-interactive break-all">
        <%= flash[:magic_link_url] %>
      </code>
    </div>
  <% end %>
</div>
