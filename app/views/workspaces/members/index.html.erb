<% content_for(:title) { t("workspaces.members.index.title") } %>
<div class="max-w-4xl mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-text-heading">
    <%= t("workspaces.members.index.title") %>
  </h1>

  <table class="mt-8 w-full">
    <thead>
      <tr class="border-b border-border">
        <th scope="col" class="text-left py-3 text-sm font-medium text-text-muted">
          <%= t("workspaces.members.index.name") %>
        </th>
        <th scope="col" class="text-left py-3 text-sm font-medium text-text-muted">
          <%= t("workspaces.members.index.email") %>
        </th>
        <th scope="col" class="text-left py-3 text-sm font-medium text-text-muted">
          <%= t("workspaces.members.index.role") %>
        </th>
        <th scope="col" class="text-left py-3 text-sm font-medium text-text-muted">
          <%= t("workspaces.members.index.status") %>
        </th>
        <th scope="col" class="text-left py-3 text-sm font-medium text-text-muted">
          <%= t("workspaces.members.index.actions") %>
        </th>
      </tr>
    </thead>
    <tbody>
      <% @memberships.each do |membership| %>
        <tr class="border-b border-border">
          <td class="py-3 text-text-heading"><%= membership.user.full_name %></td>
          <td class="py-3 text-text-muted"><%= membership.user.email_address %></td>
          <td class="py-3 text-text-muted"><%= membership.role.name %></td>
          <td class="py-3 text-text-muted">
            <% if membership.discarded? %>
              <span class="text-danger"><%= t("workspaces.members.index.deactivated") %></span>
            <% else %>
              <span class="text-success"><%= t("workspaces.members.index.active") %></span>
            <% end %>
          </td>
          <td class="py-3 space-x-2">
            <% if policy(membership).update? %>
              <%= link_to t("workspaces.members.index.edit_role"),
                    edit_workspace_member_path(@workspace, membership),
                    class: "text-sm text-interactive hover:text-interactive-hover" %>
            <% end %>
            <% if policy(membership).destroy? && !membership.discarded? %>
              <%= button_to t("workspaces.members.index.deactivate"),
                    workspace_member_path(@workspace, membership),
                    method: :delete,
                    class: "text-sm text-danger bg-transparent border-0 cursor-pointer p-0" %>
            <% end %>
            <% if policy(membership).reactivate? && membership.discarded? %>
              <%= button_to t("workspaces.members.index.reactivate"),
                    reactivate_workspace_member_path(@workspace, membership),
                    method: :patch,
                    class: "text-sm text-success bg-transparent border-0 cursor-pointer p-0" %>
            <% end %>
            <% if policy(membership).transfer_ownership? %>
              <%= button_to t("workspaces.members.index.transfer_ownership"),
                    transfer_ownership_workspace_member_path(@workspace, membership),
                    method: :patch,
                    class: "text-sm text-text-muted bg-transparent border-0 cursor-pointer p-0" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
