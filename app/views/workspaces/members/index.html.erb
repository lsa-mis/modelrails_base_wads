<% content_for(:title) { t("workspaces.members.index.title") } %>
<div class="max-w-4xl mx-auto px-4 py-16">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-text-heading">
      <%= t("workspaces.members.index.title") %>
    </h1>
    <% if policy(Invitation).create? %>
      <%= link_to t("workspaces.members.index.invite_member"),
            new_workspace_invitation_path(@workspace),
            class: "min-h-[44px] flex items-center px-4 rounded-md
                    bg-interactive hover:bg-interactive-hover text-text-on-interactive font-medium
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-interactive-focus" %>
    <% end %>
  </div>

  <%= turbo_frame_tag "members_results" do %>
    <%# Filter bar — a plain GET form inside the Turbo Frame %>
    <%= form_with url: workspace_members_path(@workspace),
          method: :get,
          data: { controller: "search-form", turbo_frame: "members_results" },
          class: "mt-6 flex flex-col gap-3 sm:flex-row sm:items-end" do |form| %>
      <div class="flex-1">
        <%= form.label :q, t("workspaces.members.index.search_placeholder"),
              class: "sr-only" %>
        <%= form.search_field :q,
              value: params[:q],
              placeholder: t("workspaces.members.index.search_placeholder"),
              data: { action: "input->search-form#search keydown->search-form#clear" },
              autocomplete: "off",
              class: "w-full min-h-[44px] rounded-md border border-border-strong
                      bg-surface-raised px-3 py-2 text-sm
                      text-text-heading placeholder:text-text-muted
                      focus:outline-none focus:ring-2 focus:ring-interactive-focus focus:border-interactive-focus" %>
      </div>

      <div class="flex gap-3">
        <%= form.select :role,
              options_for_select(
                [[t("workspaces.members.index.filter_by_role"), ""]] +
                @roles.map { |r| [r.name, r.slug] },
                params[:role]
              ),
              {},
              { onchange: "this.form.requestSubmit()",
                class: "min-h-[44px] rounded-md border border-border-strong
                        bg-surface-raised px-3 py-2 text-sm
                        text-text-heading
                        focus:outline-none focus:ring-2 focus:ring-interactive-focus focus:border-interactive-focus",
                aria: { label: t("workspaces.members.index.filter_by_role") } } %>

        <%= form.select :status,
              options_for_select(
                [[t("workspaces.members.index.filter_by_status"), ""],
                 [t("workspaces.members.index.status_active"), "active"],
                 [t("workspaces.members.index.status_deactivated"), "deactivated"]],
                params[:status]
              ),
              {},
              { onchange: "this.form.requestSubmit()",
                class: "min-h-[44px] rounded-md border border-border-strong
                        bg-surface-raised px-3 py-2 text-sm
                        text-text-heading
                        focus:outline-none focus:ring-2 focus:ring-interactive-focus focus:border-interactive-focus",
                aria: { label: t("workspaces.members.index.filter_by_status") } } %>
      </div>

      <%# Preserve sort params through filter changes %>
      <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
      <%= hidden_field_tag :direction, params[:direction] if params[:direction].present? %>
    <% end %>

    <%# Results table %>
    <% if @memberships.any? %>
      <div class="mt-6 bg-surface-raised rounded-lg border border-border shadow-sm overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-border bg-surface">
              <th scope="col" class="text-left py-3 px-2">
                <%= render "shared/sortable_header",
                      title: t("workspaces.members.index.name"),
                      column: "name",
                      current_sort: params[:sort],
                      current_direction: params[:direction],
                      url: ->(sort_params) { workspace_members_path(@workspace, request.query_parameters.merge(sort_params)) } %>
              </th>
              <th scope="col" class="text-left py-3 px-2">
                <%= render "shared/sortable_header",
                      title: t("workspaces.members.index.email"),
                      column: "email",
                      current_sort: params[:sort],
                      current_direction: params[:direction],
                      url: ->(sort_params) { workspace_members_path(@workspace, request.query_parameters.merge(sort_params)) } %>
              </th>
              <th scope="col" class="text-left py-3 px-2">
                <%= render "shared/sortable_header",
                      title: t("workspaces.members.index.role"),
                      column: "role",
                      current_sort: params[:sort],
                      current_direction: params[:direction],
                      url: ->(sort_params) { workspace_members_path(@workspace, request.query_parameters.merge(sort_params)) } %>
              </th>
              <th scope="col" class="text-left py-3 px-2 text-sm font-medium text-text-muted">
                <%= t("workspaces.members.index.status") %>
              </th>
              <th scope="col" class="text-left py-3 px-2 text-sm font-medium text-text-muted">
                <%= t("workspaces.members.index.actions") %>
              </th>
            </tr>
          </thead>
          <tbody>
            <% @memberships.each do |membership| %>
              <%= render "workspaces/members/member_row", membership: membership, workspace: @workspace %>
            <% end %>
          </tbody>
        </table>

        <%= render "shared/pagination", pagy: @pagy %>
      </div>
    <% else %>
      <p class="mt-8 text-center text-text-muted"><%= t("workspaces.members.index.empty") %></p>
    <% end %>
  <% end %>

  <%= render "workspaces/members/pending_invitations",
        workspace: @workspace,
        pending_invitations: @pending_invitations %>
</div>
