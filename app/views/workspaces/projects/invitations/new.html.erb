<% content_for(:title) { t("workspaces.projects.invitations.new.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-3xl font-bold text-text-heading">
    <%= t("workspaces.projects.invitations.new.title") %>
  </h1>

  <%= form_with model: @invitation, url: workspace_project_invitations_path(@workspace, @project),
        id: "new_project_invitation",
        class: "mt-8 space-y-6",
        data: {
          controller: "form-draft",
          action: "input->form-draft#save change->form-draft#save turbo:submit-end->form-draft#submitEnd"
        } do |form| %>
    <%= render "shared/form_draft_notice" %>

    <%= form.email_field :email,
          label: t("workspaces.projects.invitations.new.email_label"),
          required: true %>

    <%= form.select :project_role,
          [[ t("project_roles.editor"), "editor" ], [ t("project_roles.viewer"), "viewer" ]],
          { label: t("workspaces.projects.invitations.new.role_label") },
          {} %>

    <%= form.submit t("workspaces.projects.invitations.new.submit"), class: "w-full" %>
  <% end %>
</div>
