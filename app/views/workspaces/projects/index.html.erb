<% content_for(:title) { t("workspaces.projects.index.title") } %>
<div class="max-w-4xl mx-auto px-4 py-16">
  <div class="flex items-center justify-between">
    <h1 class="text-3xl font-bold text-text-heading">
      <%= t("workspaces.projects.index.title") %>
    </h1>
    <%= link_to t("workspaces.projects.index.new_project"), new_workspace_project_path(@workspace),
          class: "btn-primary" %>
  </div>

  <% if @projects.any? %>
    <div class="mt-8 grid gap-4">
      <% @projects.each do |project| %>
        <%= link_to workspace_project_path(@workspace, project),
              class: "block p-4 border border-border rounded-lg
                      hover:border-interactive
                      focus-ring" do %>
          <div class="flex items-center gap-3">
            <% if project.logo.attached? %>
              <%= image_tag project.logo, class: "w-10 h-10 rounded-full object-cover", alt: "" %>
            <% else %>
              <div class="w-10 h-10 rounded-full bg-info-surface flex items-center justify-center text-interactive font-semibold text-sm">
                <%= project.initials %>
              </div>
            <% end %>
            <div>
              <p class="font-medium text-text-heading"><%= project.name %></p>
              <p class="text-sm text-text-muted"><%= project.description&.truncate(80) %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="mt-8">
      <%= render "shared/empty_state", message: t("workspaces.projects.index.empty") %>
    </div>
  <% end %>
</div>
