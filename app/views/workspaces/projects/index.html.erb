<% content_for(:title) { t("workspaces.projects.index.title") } %>
<div class="max-w-4xl px-6 pt-4 pb-16">
  <div class="flex items-center justify-between gap-4">
    <h1 class="text-2xl font-semibold text-text-heading">
      <%= t("workspaces.projects.index.title") %>
    </h1>
    <%= link_to t("workspaces.projects.index.new_project"), new_workspace_project_path(@workspace),
          class: "btn-primary" %>
  </div>

  <% if @projects.any? %>
    <div class="mt-8 grid gap-4">
      <% @projects.each do |project| %>
        <%= link_to workspace_project_path(@workspace, project),
              class: "block p-4 border border-border rounded-lg
                      hover:border-interactive
                      focus-ring" do %>
          <div class="flex items-center gap-3">
            <% if project.logo.attached? %>
              <%= image_tag project.logo, class: "w-10 h-10 rounded-full object-cover", alt: "" %>
            <% else %>
              <div class="w-10 h-10 rounded-full bg-info-surface flex items-center justify-center text-interactive font-semibold text-sm">
                <%= project.initials %>
              </div>
            <% end %>
            <div>
              <p class="font-medium text-text-heading"><%= project.name %></p>
              <p class="text-sm text-text-muted"><%= project.description&.truncate(80) %></p>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if @archived_projects.any? %>
    <section class="mt-8" data-test="archived-projects">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-3">
        <%= t("workspaces.projects.index.archived_heading") %>
      </h2>
      <ul class="flex flex-col gap-2">
        <% @archived_projects.each do |project| %>
          <li class="flex items-center justify-between gap-4 p-4 border border-border rounded-lg bg-surface">
            <div class="min-w-0">
              <p class="font-medium text-text-heading truncate"><%= project.name %></p>
              <p class="text-sm text-text-muted"><%= lifecycle_status_label(project) %></p>
            </div>
            <%= button_to t("lifecycle.restore"), unarchive_workspace_project_path(@workspace, project),
                  method: :patch,
                  class: "btn-touch-target btn-text btn-text-interactive text-sm shrink-0" %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <% if @projects.empty? && @archived_projects.empty? %>
    <div class="mt-8">
      <%= render "shared/empty_state", message: t("workspaces.projects.index.empty") %>
    </div>
  <% end %>
</div>
