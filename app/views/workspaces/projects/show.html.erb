<% content_for(:title) { @project.name } %>
<div class="max-w-4xl mx-auto px-4 py-16">
  <%= turbo_stream_from @project %>
  <div class="flex items-center gap-4">
    <% if @project.logo.attached? %>
      <%= image_tag @project.logo, class: "w-16 h-16 rounded-full object-cover" %>
    <% else %>
      <div class="w-16 h-16 rounded-full bg-info-surface flex items-center justify-center text-interactive font-bold text-xl">
        <%= @project.initials %>
      </div>
    <% end %>
    <div>
      <h1 class="text-2xl font-bold text-text-heading"><%= @project.name %></h1>
      <% if @project.description.present? %>
        <p class="mt-1 text-text-muted"><%= @project.description %></p>
      <% end %>
    </div>
  </div>

  <nav class="mt-8 flex gap-4" aria-label="Project navigation">
    <%= link_to t("workspaces.projects.show.members"), workspace_project_memberships_path(@workspace, @project),
          class: "min-h-[44px] flex items-center px-4 py-2 rounded-md border border-border
                  text-text-body hover:border-interactive
                  focus:outline-none focus:ring-2 focus:ring-interactive-focus" %>
    <% if policy(@project).update? %>
      <%= link_to t("workspaces.projects.show.edit"), edit_workspace_project_path(@workspace, @project),
            class: "min-h-[44px] flex items-center px-4 py-2 rounded-md border border-border
                    text-text-body hover:border-interactive
                    focus:outline-none focus:ring-2 focus:ring-interactive-focus" %>
    <% end %>
  </nav>

  <%= render "shared/activity_feed", activities: ActivityLog.visible.where(trackable: @project.resources).or(ActivityLog.visible.where(trackable: @project)).or(ActivityLog.visible.where(trackable: @project.project_memberships)).or(ActivityLog.visible.where(trackable: @project.invitations)).recent.includes(:actor) %>
</div>
