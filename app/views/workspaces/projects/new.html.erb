<% content_for(:title) { t("workspaces.projects.new.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-3xl font-bold text-text-heading">
    <%= t("workspaces.projects.new.title") %>
  </h1>

  <%= form_with model: @project, url: workspace_projects_path(@workspace),
        id: dom_id(@project),
        class: "mt-8 space-y-6",
        data: {
          controller: "form-draft",
          action: "input->form-draft#save change->form-draft#save turbo:submit-end->form-draft#submitEnd"
        } do |form| %>
    <%= render "shared/form_draft_notice" %>

    <%= form.error_summary %>

    <%= form.text_field :name,
          label: t("workspaces.projects.new.name_label"),
          required: true,
          autofocus: true %>

    <%= form.text_area :description,
          label: t("workspaces.projects.new.description_label"),
          rows: 3 %>

    <%= form.submit t("workspaces.projects.new.submit"), class: "w-full" %>
  <% end %>
</div>
