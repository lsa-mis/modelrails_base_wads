<div>
  <label for="document_body" class="block text-sm font-medium text-slate-700 dark:text-gray-300">
    <%= t("resources.new.body_label") %>
  </label>
  <%= fields_for :document do |document_form| %>
    <%= document_form.rich_text_area :body,
          id: "document_body",
          class: "mt-1 block w-full rounded-md border border-gray-300 dark:border-gray-600
                  focus:outline-none focus:ring-2 focus:ring-sky-700 focus:border-sky-700" %>
  <% end %>
</div>
