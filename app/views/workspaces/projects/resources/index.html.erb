<% content_for(:title) { t("workspaces.projects.resources.index.title") } %>
<div class="max-w-4xl mx-auto px-4 py-16">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-text-heading">
      <%= t("workspaces.projects.resources.index.title") %>
    </h1>
    <% if policy(Resource).create? %>
      <%= link_to t("workspaces.projects.resources.index.new_resource"),
            new_workspace_project_resource_path(@workspace, @project),
            class: "min-h-[44px] flex items-center px-4 rounded-md
                    bg-interactive hover:bg-interactive-hover text-text-on-interactive font-medium
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-interactive-focus" %>
    <% end %>
  </div>

  <% if @resources.any? %>
    <ul class="mt-8 space-y-3" aria-label="<%= t('workspaces.projects.resources.index.title') %>">
      <% @resources.each do |resource| %>
        <li class="flex items-center justify-between border border-border rounded-lg px-4 py-3">
          <div class="flex items-center gap-3">
            <%= link_to resource.title,
                  workspace_project_resource_path(@workspace, @project, resource),
                  class: "text-interactive font-medium hover:underline
                          focus:outline-none focus:ring-2 focus:ring-interactive-focus rounded" %>
            <% if resource.draft? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                           bg-surface text-text-muted">
                <%= t("workspaces.projects.resources.index.draft") %>
              </span>
            <% else %>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                           bg-success-surface text-success">
                <%= t("workspaces.projects.resources.index.published") %>
              </span>
            <% end %>
          </div>
          <span class="text-sm text-text-muted">
            <%= t("workspaces.projects.resources.show.created_by", name: resource.created_by.full_name) %>
          </span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="mt-8">
      <%= render "shared/empty_state", message: t("workspaces.projects.resources.index.empty") %>
    </div>
  <% end %>
</div>
