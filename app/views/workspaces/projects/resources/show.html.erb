<% content_for(:title) { @resource.title } %>
<div class="max-w-4xl mx-auto px-4 py-16">
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-text-heading">
        <%= @resource.title %>
      </h1>
      <div class="mt-2 flex items-center gap-3">
        <% if @resource.draft? %>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                       bg-surface text-text-muted">
            <%= t("workspaces.projects.resources.index.draft") %>
          </span>
        <% else %>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                       bg-success-surface text-success">
            <%= t("workspaces.projects.resources.index.published") %>
          </span>
        <% end %>
        <span class="text-sm text-text-muted">
          <%= t("workspaces.projects.resources.show.created_by", name: @resource.created_by.full_name) %>
          &middot;
          <%= l @resource.created_at.to_date %>
        </span>
      </div>
    </div>
    <% if policy(@resource).update? %>
      <%= link_to t("workspaces.projects.resources.show.edit"),
            edit_workspace_project_resource_path(@workspace, @project, @resource),
            class: "min-h-[44px] flex items-center px-4 rounded-md
                    bg-interactive hover:bg-interactive-hover text-text-on-interactive font-medium
                    focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-interactive-focus" %>
    <% end %>
  </div>

  <div class="mt-8 prose dark:prose-invert max-w-none">
    <%= render "workspaces/projects/resources/types/#{@resource.resourceable_type.underscore}", resource: @resource %>
  </div>

  <div class="mt-8">
    <%= link_to t("workspaces.projects.resources.show.back"),
          workspace_project_resources_path(@workspace, @project),
          class: "text-interactive hover:underline
                  focus:outline-none focus:ring-2 focus:ring-interactive-focus rounded" %>
  </div>
</div>
