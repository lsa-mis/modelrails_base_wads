<% content_for(:title) { t("workspaces.projects.resources.new.title") } %>
<div class="max-w-2xl mx-auto px-4 py-16">
  <h1 class="text-3xl font-bold text-text-heading">
    <%= t("workspaces.projects.resources.new.title") %>
  </h1>

  <%= form_with url: workspace_project_resources_path(@workspace, @project), method: :post, class: "mt-8 space-y-6" do |form| %>
    <%= hidden_field_tag "resource[type]", @type %>

    <% if @resource.errors.any? %>
      <%= ui :alert, variant: :destructive do |alert| %>
        <% alert.with_alert_description do %>
          <ul class="list-disc list-inside">
            <% @resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        <% end %>
      <% end %>
    <% end %>

    <div>
      <label for="resource_title" class="block text-sm font-medium text-text-body">
        <%= t("workspaces.projects.resources.new.title_label") %>
      </label>
      <%= text_field_tag "resource[title]", @resource.title,
            id: "resource_title",
            class: "mt-1 block w-full rounded-md border border-border-strong
                    bg-surface-raised px-3 py-2
                    text-text-heading
                    focus-ring focus:border-interactive-focus",
            required: true,
            aria: { required: true } %>
    </div>

    <%= render "workspaces/projects/resources/types/#{@type.underscore}_form", form: form %>

    <%= submit_tag t("workspaces.projects.resources.new.submit"),
          class: "btn-primary w-full" %>
  <% end %>
</div>
