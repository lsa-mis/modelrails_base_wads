<% content_for(:title) { t("resources.new.title") } %>
<div class="max-w-2xl mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-gray-100">
    <%= t("resources.new.title") %>
  </h1>

  <%= form_with url: workspace_project_resources_path(@workspace, @project), method: :post, class: "mt-8 space-y-6" do |form| %>
    <%= hidden_field_tag "resource[type]", @type %>

    <% if @resource.errors.any? %>
      <div class="rounded-md bg-red-50 dark:bg-red-900/20 p-4" role="alert">
        <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400">
          <% @resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <label for="resource_title" class="block text-sm font-medium text-slate-700 dark:text-gray-300">
        <%= t("resources.new.title_label") %>
      </label>
      <%= text_field_tag "resource[title]", @resource.title,
            id: "resource_title",
            class: "mt-1 block w-full rounded-md border border-gray-300 dark:border-gray-600
                    bg-white dark:bg-gray-800 px-3 py-2
                    text-slate-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-sky-700 focus:border-sky-700",
            required: true %>
    </div>

    <%= render "workspaces/projects/resources/types/#{@type.underscore}_form", form: form %>

    <%= submit_tag t("resources.new.submit"),
          class: "w-full min-h-[44px] rounded-md px-4 py-2
                  bg-sky-700 hover:bg-sky-800 text-white font-medium
                  focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-sky-700
                  cursor-pointer" %>
  <% end %>
</div>
