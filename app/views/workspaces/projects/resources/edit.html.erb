<% content_for(:title) { t("workspaces.projects.resources.edit.title") } %>
<div class="max-w-2xl mx-auto px-4 py-16">
  <h1 class="text-3xl font-bold text-text-heading">
    <%= t("workspaces.projects.resources.edit.title") %>
  </h1>

  <%= form_with url: workspace_project_resource_path(@workspace, @project, @resource), method: :patch, class: "mt-8 space-y-6" do |form| %>

    <% if @resource.errors.any? %>
      <%= ui :alert, variant: :destructive do |alert| %>
        <% alert.with_alert_description do %>
          <ul class="list-disc list-inside">
            <% @resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        <% end %>
      <% end %>
    <% end %>

    <div>
      <label for="resource_title" class="block text-sm font-medium text-text-body">
        <%= t("workspaces.projects.resources.edit.title_label") %>
      </label>
      <%= text_field_tag "resource[title]", @resource.title,
            id: "resource_title",
            class: "mt-1 block w-full rounded-md border border-border-strong
                    bg-surface-raised px-3 py-2
                    text-text-heading
                    focus-ring focus:border-interactive-focus",
            required: true,
            aria: { required: true } %>
    </div>

    <div>
      <label for="resource_status" class="block text-sm font-medium text-text-body">
        <%= t("workspaces.projects.resources.edit.status_label") %>
      </label>
      <%= select_tag "resource[status]",
            options_for_select([
              [t("workspaces.projects.resources.index.draft"), "draft"],
              [t("workspaces.projects.resources.index.published"), "published"]
            ], @resource.status),
            id: "resource_status",
            class: "mt-1 block w-full rounded-md border border-border-strong
                    bg-surface-raised px-3 py-2
                    text-text-heading
                    focus-ring focus:border-interactive-focus ui-select" %>
    </div>

    <%= render "workspaces/projects/resources/types/#{@resource.resourceable_type.underscore}_form", form: form %>

    <% if @project.clientside_enabled? %>
      <div>
        <%= hidden_field_tag "resource[shared_with_client]", "0" %>
        <label class="flex items-center gap-2 text-sm text-text-body">
          <%= check_box_tag "resource[shared_with_client]", "1", @resource.shared_with_client?,
                id: "resource_shared_with_client", class: "focus-ring rounded" %>
          <%= t("workspaces.projects.resources.edit.share_with_client") %>
        </label>
      </div>
    <% end %>

    <%= submit_tag t("workspaces.projects.resources.edit.submit"),
          class: "btn-primary w-full" %>
  <% end %>
</div>
