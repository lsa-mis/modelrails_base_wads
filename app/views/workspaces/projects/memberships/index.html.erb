<% content_for(:title) { t("workspaces.projects.memberships.index.title") } %>
<div class="max-w-4xl mx-auto px-4 py-16">
  <div class="flex items-center justify-between">
    <h1 class="text-3xl font-bold text-text-heading">
      <%= t("workspaces.projects.memberships.index.title") %>
    </h1>
    <% if policy(ProjectMembership).create? %>
      <%= link_to t("workspaces.projects.memberships.index.add_member"),
            workspace_project_memberships_path(@workspace, @project),
            class: "btn-primary" %>
    <% end %>
  </div>

  <div class="mt-8 bg-surface-raised rounded-lg border border-border shadow-sm overflow-hidden">
    <table class="w-full" aria-label="<%= t('workspaces.projects.memberships.index.table_label') %>">
      <thead>
        <tr class="border-b border-border bg-surface">
          <th scope="col" class="text-left py-3 px-2 text-sm font-medium text-text-muted"><%= t("workspaces.projects.memberships.index.name_header") %></th>
          <th scope="col" class="text-left py-3 px-2 text-sm font-medium text-text-muted"><%= t("workspaces.projects.memberships.index.role") %></th>
          <th scope="col" class="text-left py-3 px-2 text-sm font-medium text-text-muted"><%= t("workspaces.projects.memberships.index.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @memberships.each do |pm| %>
          <tr class="border-b border-border hover:bg-surface-sunken transition-colors">
            <td class="py-3 px-2 text-text-heading"><%= pm.user.full_name %></td>
            <td class="py-3 px-2 text-text-muted"><%= pm.role.titleize %></td>
            <td class="py-3 px-2 flex gap-2">
              <% if policy(pm).destroy? %>
                <%= button_to t("workspaces.projects.memberships.index.remove"),
                      workspace_project_membership_path(@workspace, @project, pm),
                      method: :delete,
                      class: "text-sm text-danger underline hover:no-underline cursor-pointer
                              focus-ring rounded" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
