<% content_for(:title) { t("pages.contact.title") } %>

<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
  <h1 class="text-sm font-medium text-slate-500 dark:text-gray-400"><%= t("pages.contact.title") %></h1>
</section>

<%= render "shared/hero",
      title: t("pages.contact.hero.title"),
      subtitle: t("pages.contact.hero.subtitle") %>

<%= render "shared/section",
      title: t("pages.contact.methods.title"),
      bg: "bg-gray-50 dark:bg-gray-800" do %>
  <div class="grid sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
    <%= render "shared/feature_card",
          title: t("pages.contact.methods.email.title"),
          description: t("pages.contact.methods.email.description") %>
    <%= render "shared/feature_card",
          title: t("pages.contact.methods.bugs.title"),
          description: t("pages.contact.methods.bugs.description") %>
  </div>
<% end %>

<%= render "shared/section",
      title: t("pages.contact.community.title"),
      bg: "bg-white dark:bg-gray-900" do %>
  <div class="grid sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
    <% %w[github discussions docs].each do |channel| %>
      <%= render "shared/feature_card",
            title: t("pages.contact.community.#{channel}.title"),
            description: t("pages.contact.community.#{channel}.description") %>
    <% end %>
  </div>
<% end %>
