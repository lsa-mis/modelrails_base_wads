<% content_for(:title) { t("pages.privacy.title") } %>

<section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <h1 class="text-4xl font-bold text-slate-900 dark:text-gray-100">
    <%= t("pages.privacy.title") %>
  </h1>
  <p class="mt-4 text-slate-600 dark:text-gray-400">
    <%= t("pages.privacy.intro") %>
  </p>

  <% %w[collection usage].each do |section| %>
    <div class="mt-10">
      <h2 class="text-2xl font-semibold text-slate-900 dark:text-gray-100">
        <%= t("pages.privacy.#{section}.title") %>
      </h2>
      <ul class="mt-4 space-y-2">
        <% t("pages.privacy.#{section}.items").each do |item| %>
          <li class="flex items-start gap-2 text-slate-700 dark:text-gray-300">
            <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-sky-700 dark:bg-sky-400 flex-shrink-0" aria-hidden="true"></span>
            <%= item %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mt-10">
    <h2 class="text-2xl font-semibold text-slate-900 dark:text-gray-100">
      <%= t("pages.privacy.sharing.title") %>
    </h2>
    <p class="mt-4 text-slate-700 dark:text-gray-300"><%= t("pages.privacy.sharing.description") %></p>
  </div>

  <div class="mt-10">
    <h2 class="text-2xl font-semibold text-slate-900 dark:text-gray-100">
      <%= t("pages.privacy.security.title") %>
    </h2>
    <p class="mt-4 text-slate-700 dark:text-gray-300"><%= t("pages.privacy.security.description") %></p>
  </div>

  <div class="mt-10">
    <h2 class="text-2xl font-semibold text-slate-900 dark:text-gray-100">
      <%= t("pages.privacy.rights.title") %>
    </h2>
    <ul class="mt-4 space-y-2">
      <% t("pages.privacy.rights.items").each do |item| %>
        <li class="flex items-start gap-2 text-slate-700 dark:text-gray-300">
          <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-sky-700 dark:bg-sky-400 flex-shrink-0" aria-hidden="true"></span>
          <%= item %>
        </li>
      <% end %>
    </ul>
  </div>

  <div class="mt-10 text-sm text-slate-500 dark:text-gray-500">
    <p>
      <%= t("pages.privacy.contact_text") %>
      <%= link_to t("pages.privacy.contact_link"), contact_path,
            class: "text-sky-700 dark:text-sky-400 underline hover:no-underline
                    focus:outline-none focus:ring-2 focus:ring-sky-700 rounded" %>.
    </p>
    <p class="mt-2"><%= t("pages.privacy.updated") %>: <%= Date.current.strftime("%B %d, %Y") %></p>
  </div>
</section>
