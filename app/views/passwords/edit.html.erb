<% content_for(:title) { t("passwords.edit.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-text-heading">
    <%= t("passwords.edit.title") %>
  </h1>

  <%= form_with model: @user, url: password_path(params[:token]), method: :patch, class: "mt-8 space-y-6" do |form| %>
    <%= form.error_summary %>

    <%= form.password_field :password,
          label: t("passwords.edit.password_label"),
          required: true,
          autocomplete: "new-password",
          help: t("passwords.edit.password_hint") %>

    <%= form.password_field :password_confirmation,
          label: t("passwords.edit.password_confirmation_label"),
          required: true,
          autocomplete: "new-password" %>

    <%= form.submit t("passwords.edit.submit"), class: "w-full" %>
  <% end %>
</div>
