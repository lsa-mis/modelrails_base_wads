<% content_for(:title) { t("passwords.new.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-text-heading">
    <%= t("passwords.new.title") %>
  </h1>

  <p class="mt-2 text-text-muted">
    <%= t("passwords.new.instructions") %>
  </p>

  <%= form_with url: passwords_path, class: "mt-8 space-y-6" do |form| %>
    <%= form.email_field :email_address,
          label: t("passwords.new.email_label"),
          required: true,
          autofocus: true,
          autocomplete: "email" %>

    <%= form.submit t("passwords.new.submit"), class: "w-full" %>
  <% end %>

  <p class="mt-6 text-center text-text-muted">
    <%= link_to t("passwords.new.back_to_sign_in"), new_session_path,
          class: "text-interactive underline hover:no-underline
                  focus:outline-none focus:ring-2 focus:ring-interactive-focus rounded" %>
  </p>
</div>
