<% content_for(:title) { t("passwords.new.title") } %>
<div class="max-w-md mx-auto px-4 py-16">
  <h1 class="text-2xl font-bold text-slate-900 dark:text-gray-100">
    <%= t("passwords.new.title") %>
  </h1>

  <p class="mt-2 text-slate-600 dark:text-gray-400">
    <%= t("passwords.new.instructions") %>
  </p>

  <%= form_with url: passwords_path, class: "mt-8 space-y-6" do |form| %>
    <div>
      <%= form.label :email_address, t("passwords.new.email_label"),
            class: "block text-sm font-medium text-slate-700 dark:text-gray-300" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "email",
            class: "mt-1 block w-full rounded-md border border-gray-300 dark:border-gray-600
                    bg-white dark:bg-gray-800 px-3 py-2
                    text-slate-900 dark:text-gray-100
                    focus:outline-none focus:ring-2 focus:ring-cyan-700 focus:border-cyan-700" %>
    </div>

    <%= form.submit t("passwords.new.submit"),
          class: "w-full min-h-[44px] rounded-md px-4 py-2
                  bg-cyan-700 hover:bg-cyan-800 text-white font-medium
                  focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-cyan-700
                  cursor-pointer" %>
  <% end %>

  <p class="mt-6 text-center text-slate-600 dark:text-gray-400">
    <%= link_to t("passwords.new.back_to_sign_in"), new_session_path,
          class: "text-cyan-700 dark:text-cyan-400 underline hover:no-underline
                  focus:outline-none focus:ring-2 focus:ring-cyan-700 rounded" %>
  </p>
</div>
