<%# App override of biscuit-rails' default banner partial (app/views paths
    take precedence over the gem's own views at the same relative path — see
    Biscuit::BiscuitHelper#biscuit_banner). Every data-controller /
    data-biscuit-target / data-action below is preserved VERBATIM from the
    gem's own partial so biscuit_controller.js keeps driving this markup
    unmodified — only the CONTENT and CONDITIONAL STRUCTURE changed.

    Two server-chosen layouts:
      - First visit (!consent.given?): compliant, privacy-forward defaults —
        Reject non-essential is the emphasized primary action (rejecting
        must be at least as easy as accepting; emphasizing Accept is a
        documented dark pattern). Non-essential checkboxes start unchecked
        (affirmative consent). The manage-preferences toggle stays, for
        users who want granular categories on their first decision.
      - Manage mode (consent.given?, reopened via the footer link): the
        accept/reject/manage shortcuts don't apply to an already-made
        decision, so they're dropped entirely — only the category
        checkboxes (pre-filled from the saved choice) + Save.

    The banner's `hidden` attribute is set HERE, server-side, when
    consent.given? — NOT via a CSS rule keyed on the already-consented data
    attribute. A CSS-based hide pins the banner hidden permanently (it can
    never un-hide on reopen, since the attribute it's keyed on never
    reverts) — that mistake shipped once and was reverted. The native
    `hidden` ATTRIBUTE avoids the pre-Stimulus-connect flash AND lets the
    gem's own JS (`reopen()` → `this.bannerTarget.hidden = false`) correctly
    un-hide it later, because JS is toggling the same attribute CSS isn't
    fighting over. -%>
<div data-controller="biscuit"
     data-biscuit-position-value="<%= Biscuit.configuration.position %>"
     data-biscuit-csrf-token-value="<%= form_authenticity_token %>"
     data-biscuit-endpoint-value="<%= biscuit.consent_path %>"
     data-biscuit-already-consented-value="<%= consent.given? %>">

<%= tag.div class: "biscuit-banner", data: { biscuit_target: "banner" }, role: "dialog",
      aria: { label: t("biscuit.banner.aria_label"), modal: "false" }, hidden: consent.given? do %>

  <div class="biscuit-banner__inner">
    <% if consent.given? %>
      <p class="biscuit-banner__message">
        <%= t("cookie_consent.manage_message") %>
      </p>
    <% else %>
      <p class="biscuit-banner__message">
        <%= t("biscuit.banner.message") %>
        <a href="<%= Biscuit.configuration.privacy_policy_url %>" class="biscuit-learn-more">
          <%= t("biscuit.banner.learn_more") %>
        </a>
      </p>
    <% end %>

    <% unless consent.given? %>
      <div class="biscuit-banner__actions">
        <%= tag.button t("cookie_consent.reject_non_essential"),
              type: "button",
              class: "biscuit-btn biscuit-btn--primary",
              data: { action: "click->biscuit#rejectAll" },
              aria: { label: t("cookie_consent.reject_non_essential") } %>

        <%= tag.button t("biscuit.banner.accept_all"),
              type: "button",
              class: "biscuit-btn biscuit-btn--secondary",
              data: { action: "click->biscuit#acceptAll" },
              aria: { label: t("biscuit.banner.accept_all") } %>

        <%= tag.button t("biscuit.banner.manage"),
              type: "button",
              class: "biscuit-btn biscuit-btn--secondary",
              data: { action: "click->biscuit#togglePreferences" },
              aria: { expanded: "false", controls: "biscuit-preferences-panel" } %>
      </div>
    <% end %>

    <%= tag.div id: "biscuit-preferences-panel",
          class: [ "biscuit-preferences", ("biscuit-preferences--open" if consent.given?) ].compact.join(" "),
          data: { biscuit_target: "preferencesPanel" },
          hidden: !consent.given?,
          aria: { label: t("biscuit.banner.manage") } do %>

      <% Biscuit.configuration.categories.each do |key, opts| %>
        <div class="biscuit-preference-row">
          <% checkbox_id = "biscuit-category-#{key}" %>

          <% if opts[:required] %>
            <%= tag.input type: "checkbox", id: checkbox_id, checked: true, disabled: true,
                  aria: { label: t("biscuit.categories.#{key}.name"), describedby: "#{checkbox_id}-desc" } %>
          <% else %>
            <%= tag.input type: "checkbox", id: checkbox_id,
                  data: { biscuit_target: "categoryCheckbox", category: key },
                  checked: consent.given? && consent.allowed?(key),
                  aria: { label: t("biscuit.categories.#{key}.name"), describedby: "#{checkbox_id}-desc" } %>
          <% end %>

          <div class="biscuit-preference-row__label">
            <label for="<%= checkbox_id %>" class="biscuit-preference-row__name">
              <%= t("biscuit.categories.#{key}.name") %>
              <% if opts[:required] %>
                <span aria-hidden="true"> (required)</span>
              <% end %>
            </label>
            <span id="<%= checkbox_id %>-desc" class="biscuit-preference-row__description">
              <%= t("biscuit.categories.#{key}.description") %>
            </span>
          </div>
        </div>
      <% end %>

      <div class="biscuit-preferences__footer">
        <%# Manage mode only (consent already given): let the user dismiss the
            reopened panel without re-deciding. NOT rendered on first visit, so
            an initial consent choice still can't be dodged. Wired to the small
            biscuit-cancel controller (the gem exposes no public close action —
            reopen()'s inverse #hideBanner/#showManageLink are private). %>
        <% if consent.given? %>
          <button type="button"
                  class="biscuit-btn biscuit-btn--secondary"
                  data-controller="biscuit-cancel"
                  data-action="click->biscuit-cancel#dismiss">
            <%= t("cookie_consent.cancel") %>
          </button>
        <% end %>
        <button type="button"
                class="biscuit-btn biscuit-btn--primary"
                data-action="click->biscuit#savePreferences">
          <%= t("biscuit.banner.save") %>
        </button>
      </div>
    <% end %>
  </div>
<% end %>

<button type="button"
        class="biscuit-manage-link"
        data-biscuit-target="manageLink"
        data-biscuit-position-value="<%= Biscuit.configuration.position %>"
        data-action="click->biscuit#reopen"
        hidden
        aria-label="<%= t("biscuit.banner.reopen") %>">
  <%= t("biscuit.banner.reopen") %>
</button>

</div>
